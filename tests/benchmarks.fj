// FajarOS Nova v2.0 — Benchmark Suite (Sprint 4.6)
// tests/benchmarks.fj — Ring 0 ONLY
// Comprehensive performance benchmarks: IPC, context switch, memory, matmul, VFS
// All functions @kernel annotated. Uses rdtsc() for cycle-accurate timing.

// ═══════════════════════════════════════════════════════════════
// Memory Layout — Benchmark scratch area at 0x9C0000 (16KB)
// ═══════════════════════════════════════════════════════════════

const BENCH_BASE: i64 = 0x9C0000
const BENCH_SCRATCH: i64 = 0x9C1000    // 4KB scratch for matmul/memcpy
const BENCH_MSG_BUF: i64 = 0x9C2000    // 64-byte IPC message buffer
const BENCH_REPLY_BUF: i64 = 0x9C2040  // 64-byte IPC reply buffer
const BENCH_SENDER_BUF: i64 = 0x9C2080 // 8-byte sender PID output
const BENCH_MEMCPY_SRC: i64 = 0x9C3000 // 4KB source for memcpy bench
const BENCH_MEMCPY_DST: i64 = 0x9C4000 // 4KB dest for memcpy bench

// Result storage: 8 benchmarks x 48 bytes (name_hash, iters, total, min, avg, max)
const BENCH_RESULTS: i64 = 0x9C0800
const BENCH_MAX_RESULTS: i64 = 8
const BENCH_RESULT_SIZE: i64 = 48

// Estimated CPU frequency (2 GHz default — adjust for actual hardware)
const CPU_FREQ_GHZ: i64 = 2

// ═══════════════════════════════════════════════════════════════
// Section 1: Result Tracking
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_result_store(slot: i64, iters: i64, total: i64, min_c: i64, max_c: i64) {
    if slot < 0 || slot >= BENCH_MAX_RESULTS { return }
    let addr = BENCH_RESULTS + slot * BENCH_RESULT_SIZE
    volatile_write_u64(addr, iters)
    volatile_write_u64(addr + 8, total)
    volatile_write_u64(addr + 16, min_c)
    volatile_write_u64(addr + 24, max_c)
    if iters > 0 {
        volatile_write_u64(addr + 32, total / iters)  // avg
    } else {
        volatile_write_u64(addr + 32, 0)
    }
    // estimated microseconds = total_cycles / (freq_ghz * 1000)
    if iters > 0 {
        volatile_write_u64(addr + 40, (total / iters) / CPU_FREQ_GHZ / 1000)
    } else {
        volatile_write_u64(addr + 40, 0)
    }
}

@kernel fn bench_print_row(name: str, slot: i64) {
    let addr = BENCH_RESULTS + slot * BENCH_RESULT_SIZE
    let iters = volatile_read_u64(addr)
    let total = volatile_read_u64(addr + 8)
    let min_c = volatile_read_u64(addr + 16)
    let max_c = volatile_read_u64(addr + 24)
    let avg_c = volatile_read_u64(addr + 32)
    let est_us = volatile_read_u64(addr + 40)

    cprint("  ", WHITE_ON_BLACK)
    cprint(name, CYAN_ON_BLACK)
    // Pad to 20 chars
    let nlen = str_len(name)
    let mut pad: i64 = 0
    while pad < 20 - nlen { cprint(" ", WHITE_ON_BLACK); pad = pad + 1 }
    cprint_decimal(iters, WHITE_ON_BLACK)
    cprint("    ", WHITE_ON_BLACK)
    cprint_decimal(total, WHITE_ON_BLACK)
    cprint("    ", WHITE_ON_BLACK)
    cprint_decimal(avg_c, GREEN_ON_BLACK)
    cprint("    ", WHITE_ON_BLACK)
    cprint_decimal(min_c, CYAN_ON_BLACK)
    cprint("/", WHITE_ON_BLACK)
    cprint_decimal(max_c, YELLOW_ON_BLACK)
    cprint("    ~", WHITE_ON_BLACK)
    cprint_decimal(est_us, GREEN_ON_BLACK)
    cprintln("us", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════════════════════
// Section 2: IPC Latency Benchmark
// Measure ipc_queue_push + ipc_queue_pop round-trip
// Target: <2000 cycles per trip (~1us at 2GHz)
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_ipc_latency(iterations: i64) {
    let my_pid = volatile_read_u64(0x6FE00)
    let msg = BENCH_MSG_BUF
    let reply = BENCH_REPLY_BUF
    let sender = BENCH_SENDER_BUF

    let mut min_c: i64 = 0x7FFFFFFFFFFFFFFF
    let mut max_c: i64 = 0
    let mut total: i64 = 0
    let mut i: i64 = 0

    // Warm up IPC queues
    ipc_msg_clear(msg)
    ipc_msg_set_header(msg, my_pid, 0x42, 0)

    while i < iterations {
        ipc_msg_clear(msg)
        ipc_msg_set_header(msg, my_pid, 0x42, i)

        let t0 = rdtsc()
        ipc_queue_push(my_pid, my_pid, msg)
        ipc_queue_pop(my_pid, sender, reply)
        let elapsed = rdtsc() - t0

        total = total + elapsed
        if elapsed < min_c { min_c = elapsed }
        if elapsed > max_c { max_c = elapsed }
        i = i + 1
    }

    bench_result_store(0, iterations, total, min_c, max_c)

    cprint("  IPC latency: ", WHITE_ON_BLACK)
    cprint_decimal(total / iterations, GREEN_ON_BLACK)
    cprint(" cyc/trip avg (min=", WHITE_ON_BLACK)
    cprint_decimal(min_c, CYAN_ON_BLACK)
    cprint(" max=", WHITE_ON_BLACK)
    cprint_decimal(max_c, YELLOW_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)

    // Target check
    let avg = total / iterations
    if avg < 2000 {
        cprint("    Target <2000 cyc: ", WHITE_ON_BLACK)
        cprintln("PASS", GREEN_ON_BLACK)
    } else {
        cprint("    Target <2000 cyc: ", WHITE_ON_BLACK)
        cprint("MISS (", YELLOW_ON_BLACK)
        cprint_decimal(avg, YELLOW_ON_BLACK)
        cprintln(")", YELLOW_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════════════════════
// Section 3: Context Switch Benchmark
// Measure process state transition overhead
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_ctx_switch(iterations: i64) {
    // Create a temporary process for state toggling
    let test_pid = proc_v2_alloc()
    if test_pid < 0 {
        cprintln("  ctx_switch: no free PID", RED_ON_BLACK)
        bench_result_store(1, 0, 0, 0, 0)
        return
    }
    proc_v2_set(test_pid, 0, PROC_STATE_READY)
    proc_v2_set(test_pid, 8, test_pid)

    let mut min_c: i64 = 0x7FFFFFFFFFFFFFFF
    let mut max_c: i64 = 0
    let mut total: i64 = 0
    let mut i: i64 = 0

    while i < iterations {
        let t0 = rdtsc()
        // Simulate: READY -> RUNNING (scheduler pick)
        proc_v2_set(test_pid, 0, PROC_STATE_RUNNING)
        // Simulate: RUNNING -> READY (preempt)
        proc_v2_set(test_pid, 0, PROC_STATE_READY)
        let elapsed = rdtsc() - t0

        total = total + elapsed
        if elapsed < min_c { min_c = elapsed }
        if elapsed > max_c { max_c = elapsed }
        i = i + 1
    }

    // Measure smp_schedule overhead (10 calls averaged)
    smp_queue_add(0, test_pid)
    let sched_t0 = rdtsc()
    let mut s: i64 = 0
    while s < 10 {
        proc_v2_set(test_pid, 0, PROC_STATE_READY)
        smp_schedule(0)
        proc_v2_set(test_pid, 0, PROC_STATE_READY)
        s = s + 1
    }
    let sched_elapsed = (rdtsc() - sched_t0) / 10
    smp_queue_remove(0, test_pid)

    // Cleanup: free the test process
    proc_v2_set(test_pid, 0, PROC_STATE_FREE)

    bench_result_store(1, iterations, total, min_c, max_c)

    cprint("  Ctx switch: ", WHITE_ON_BLACK)
    cprint_decimal(total / iterations, GREEN_ON_BLACK)
    cprint(" cyc/pair avg", WHITE_ON_BLACK)
    cprint("  smp_schedule: ~", WHITE_ON_BLACK)
    cprint_decimal(sched_elapsed, CYAN_ON_BLACK)
    cprintln(" cyc", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════════════════════
// Section 4: Fast IPC vs Normal IPC Comparison
// Compare fastpath register transfer to queue IPC
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_fast_vs_normal(iterations: i64) {
    let my_pid = volatile_read_u64(0x6FE00)
    fastpath_init()

    // --- Fast IPC ---
    let fast_t0 = rdtsc()
    let mut i: i64 = 0
    while i < iterations {
        ipc_fast_send(my_pid, 0xAAAA + i, 0xBBBB + i)
        ipc_fast_recv()
        i = i + 1
    }
    let fast_total = rdtsc() - fast_t0

    // --- Normal IPC queue ---
    let msg = BENCH_MSG_BUF
    let reply = BENCH_REPLY_BUF
    let sender = BENCH_SENDER_BUF
    let normal_t0 = rdtsc()
    i = 0
    while i < iterations {
        ipc_msg_clear(msg)
        ipc_msg_set_header(msg, my_pid, 0x42, i)
        ipc_queue_push(my_pid, my_pid, msg)
        ipc_queue_pop(my_pid, sender, reply)
        i = i + 1
    }
    let normal_total = rdtsc() - normal_t0

    let fast_avg = fast_total / iterations
    let normal_avg = normal_total / iterations

    bench_result_store(2, iterations, fast_total, fast_avg, fast_avg)

    cprint("  Fast IPC: ", WHITE_ON_BLACK)
    cprint_decimal(fast_avg, GREEN_ON_BLACK)
    cprint(" cyc/msg  Normal: ", WHITE_ON_BLACK)
    cprint_decimal(normal_avg, CYAN_ON_BLACK)
    cprintln(" cyc/msg", WHITE_ON_BLACK)

    if fast_total > 0 {
        let speedup = normal_total / fast_total
        cprint("    Speedup: ~", WHITE_ON_BLACK)
        cprint_decimal(speedup, GREEN_ON_BLACK)
        cprintln("x", GREEN_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════════════════════
// Section 5: Memory Allocation Benchmark
// frame_alloc + frame_free cycles per operation
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_frame_alloc(iterations: i64) {
    let mut min_c: i64 = 0x7FFFFFFFFFFFFFFF
    let mut max_c: i64 = 0
    let mut total: i64 = 0
    let mut i: i64 = 0
    let mut alloc_fail: i64 = 0

    while i < iterations {
        let t0 = rdtsc()
        let addr = frame_alloc()
        if addr != -1 {
            frame_free(addr)
        } else {
            alloc_fail = alloc_fail + 1
        }
        let elapsed = rdtsc() - t0

        total = total + elapsed
        if elapsed < min_c { min_c = elapsed }
        if elapsed > max_c { max_c = elapsed }
        i = i + 1
    }

    bench_result_store(3, iterations, total, min_c, max_c)

    cprint("  Frame alloc: ", WHITE_ON_BLACK)
    cprint_decimal(total / iterations, GREEN_ON_BLACK)
    cprint(" cyc/op avg (min=", WHITE_ON_BLACK)
    cprint_decimal(min_c, CYAN_ON_BLACK)
    cprint(" max=", WHITE_ON_BLACK)
    cprint_decimal(max_c, YELLOW_ON_BLACK)
    cprint(")", WHITE_ON_BLACK)
    if alloc_fail > 0 {
        cprint("  fails=", WHITE_ON_BLACK)
        cprint_decimal(alloc_fail, RED_ON_BLACK)
    }
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════════════════════
// Section 6: TCP Throughput (simulated) — Memory Copy Speed
// Copy N bytes and calculate MB/s as proxy for throughput
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_memcpy_throughput(size: i64) {
    // Clamp to available scratch space (4KB max)
    let actual_size = if size > 4096 { 4096 } else { size }

    // Initialize source buffer
    let mut i: i64 = 0
    while i < actual_size {
        volatile_write_u8(BENCH_MEMCPY_SRC + i, (i & 0xFF))
        i = i + 1
    }

    // Clear destination
    i = 0
    while i < actual_size {
        volatile_write_u8(BENCH_MEMCPY_DST + i, 0)
        i = i + 1
    }

    // Measure copy (10 iterations for accuracy)
    let copy_iters: i64 = 10
    let t0 = rdtsc()
    let mut iter: i64 = 0
    while iter < copy_iters {
        i = 0
        // Copy 8 bytes at a time for speed
        while i + 8 <= actual_size {
            volatile_write_u64(BENCH_MEMCPY_DST + i, volatile_read_u64(BENCH_MEMCPY_SRC + i))
            i = i + 8
        }
        // Copy remaining bytes
        while i < actual_size {
            volatile_write_u8(BENCH_MEMCPY_DST + i, volatile_read_u8(BENCH_MEMCPY_SRC + i))
            i = i + 1
        }
        iter = iter + 1
    }
    let total_cycles = rdtsc() - t0
    let total_bytes = actual_size * copy_iters

    // Verify integrity
    let mut errors: i64 = 0
    i = 0
    while i < actual_size {
        let expected = (i & 0xFF)
        let got = volatile_read_u8(BENCH_MEMCPY_DST + i)
        if got != expected { errors = errors + 1 }
        i = i + 1
    }

    // MB/s = total_bytes / (total_cycles / cpu_freq_hz)
    //       = total_bytes * cpu_freq_ghz * 1000 / total_cycles  (in KB/s scaled)
    let cycles_per_byte = total_cycles / total_bytes

    bench_result_store(4, copy_iters, total_cycles, cycles_per_byte, cycles_per_byte)

    cprint("  Memcpy ", WHITE_ON_BLACK)
    cprint_decimal(actual_size, CYAN_ON_BLACK)
    cprint("B x", WHITE_ON_BLACK)
    cprint_decimal(copy_iters, CYAN_ON_BLACK)
    cprint(": ", WHITE_ON_BLACK)
    cprint_decimal(total_cycles, WHITE_ON_BLACK)
    cprint(" cyc (", WHITE_ON_BLACK)
    cprint_decimal(cycles_per_byte, GREEN_ON_BLACK)
    cprint(" cyc/byte)", WHITE_ON_BLACK)
    if errors > 0 {
        cprint(" ERRORS=", RED_ON_BLACK)
        cprint_decimal(errors, RED_ON_BLACK)
    } else {
        cprint(" integrity=OK", GREEN_ON_BLACK)
    }
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════════════════════
// Section 7: GPU Matmul Benchmark
// cpu_matmul at different sizes, report cycles and GFLOPS estimate
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_matmul_size(n: i64, _slot: i64) {
    // Allocate A, B, C in scratch area
    let a_addr = BENCH_SCRATCH
    let b_addr = BENCH_SCRATCH + n * n * 8
    let c_addr = BENCH_SCRATCH + n * n * 8 * 2

    // Initialize A and B with simple values
    let mut i: i64 = 0
    while i < n * n {
        volatile_write_u64(a_addr + i * 8, (i % n) + 1)
        volatile_write_u64(b_addr + i * 8, ((i / n) % n) + 1)
        i = i + 1
    }

    // Clear C
    i = 0
    while i < n * n {
        volatile_write_u64(c_addr + i * 8, 0)
        i = i + 1
    }

    let t0 = rdtsc()
    cpu_matmul(a_addr, b_addr, c_addr, n, n, n)
    let elapsed = rdtsc() - t0

    // FLOPS = 2 * n^3 (multiply + accumulate)
    let flops = 2 * n * n * n

    cprint("    ", WHITE_ON_BLACK)
    cprint_decimal(n, CYAN_ON_BLACK)
    cprint("x", WHITE_ON_BLACK)
    cprint_decimal(n, CYAN_ON_BLACK)
    cprint(": ", WHITE_ON_BLACK)
    cprint_decimal(elapsed, GREEN_ON_BLACK)
    cprint(" cyc, ", WHITE_ON_BLACK)
    cprint_decimal(flops, CYAN_ON_BLACK)
    cprint(" FLOPS", WHITE_ON_BLACK)
    if elapsed > 0 {
        // FLOPS per cycle
        let fpc = flops / elapsed
        cprint(" (", WHITE_ON_BLACK)
        cprint_decimal(fpc, GREEN_ON_BLACK)
        cprint(" FLOP/cyc)", WHITE_ON_BLACK)
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn bench_matmul() {
    cprintln("  Matmul benchmarks:", WHITE_ON_BLACK)
    bench_matmul_size(4, 5)
    bench_matmul_size(8, 5)
    bench_matmul_size(16, 5)
    // 32x32 needs 32*32*8*3 = 24576 bytes — fits in 4KB scratch only up to ~12x12
    // Use BENCH_MEMCPY_SRC/DST as overflow area for 32x32
    let n32: i64 = 32
    let a32 = BENCH_SCRATCH
    let b32 = BENCH_MEMCPY_SRC
    let c32 = BENCH_MEMCPY_DST

    let mut i: i64 = 0
    while i < n32 * n32 {
        volatile_write_u64(a32 + i * 8, (i % n32) + 1)
        volatile_write_u64(b32 + i * 8, ((i / n32) % n32) + 1)
        volatile_write_u64(c32 + i * 8, 0)
        i = i + 1
    }

    let t0 = rdtsc()
    cpu_matmul(a32, b32, c32, n32, n32, n32)
    let elapsed = rdtsc() - t0
    let flops = 2 * n32 * n32 * n32

    cprint("    32x32: ", WHITE_ON_BLACK)
    cprint_decimal(elapsed, GREEN_ON_BLACK)
    cprint(" cyc, ", WHITE_ON_BLACK)
    cprint_decimal(flops, CYAN_ON_BLACK)
    cprint(" FLOPS", WHITE_ON_BLACK)
    if elapsed > 0 {
        let fpc = flops / elapsed
        cprint(" (", WHITE_ON_BLACK)
        cprint_decimal(fpc, GREEN_ON_BLACK)
        cprint(" FLOP/cyc)", WHITE_ON_BLACK)
    }
    console_putchar(10, WHITE_ON_BLACK)

    // Store 32x32 result as representative
    bench_result_store(5, 1, elapsed, elapsed, elapsed)
}

// ═══════════════════════════════════════════════════════════════
// Section 8: VFS Operations Benchmark
// open/read/close /proc/version via IPC chain
// ═══════════════════════════════════════════════════════════════

@kernel fn bench_vfs_read(iterations: i64) {
    let msg = BENCH_MSG_BUF
    let reply = BENCH_REPLY_BUF

    let mut min_c: i64 = 0x7FFFFFFFFFFFFFFF
    let mut max_c: i64 = 0
    let mut total: i64 = 0
    let mut i: i64 = 0
    let mut fail_count: i64 = 0

    while i < iterations {
        let t0 = rdtsc()

        // Open /proc/version
        ipc_msg_clear(msg)
        ipc_msg_set_header(msg, 0, MSG_VFS_OPEN, 0)
        // Write path "/proc/version" into msg payload at +16
        volatile_write_u8(msg + 16, 47)   // '/'
        volatile_write_u8(msg + 17, 112)  // 'p'
        volatile_write_u8(msg + 18, 114)  // 'r'
        volatile_write_u8(msg + 19, 111)  // 'o'
        volatile_write_u8(msg + 20, 99)   // 'c'
        volatile_write_u8(msg + 21, 47)   // '/'
        volatile_write_u8(msg + 22, 118)  // 'v'
        volatile_write_u8(msg + 23, 101)  // 'e'
        volatile_write_u8(msg + 24, 114)  // 'r'
        volatile_write_u8(msg + 25, 115)  // 's'
        volatile_write_u8(msg + 26, 105)  // 'i'
        volatile_write_u8(msg + 27, 111)  // 'o'
        volatile_write_u8(msg + 28, 110)  // 'n'
        volatile_write_u8(msg + 29, 0)    // null
        ipc_msg_clear(reply)
        vfs_svc_handle_msg(0, msg, reply)
        let fd = volatile_read_u64(reply + 16)

        if fd >= 0 {
            // Read
            ipc_msg_clear(msg)
            ipc_msg_set_header(msg, 0, MSG_VFS_READ, 0)
            volatile_write_u64(msg + 16, fd)
            volatile_write_u64(msg + 24, 0)   // offset
            volatile_write_u64(msg + 32, 32)  // length
            ipc_msg_clear(reply)
            vfs_svc_handle_msg(0, msg, reply)

            // Close
            ipc_msg_clear(msg)
            ipc_msg_set_header(msg, 0, MSG_VFS_CLOSE, 0)
            volatile_write_u64(msg + 16, fd)
            ipc_msg_clear(reply)
            vfs_svc_handle_msg(0, msg, reply)
        } else {
            fail_count = fail_count + 1
        }

        let elapsed = rdtsc() - t0
        total = total + elapsed
        if elapsed < min_c { min_c = elapsed }
        if elapsed > max_c { max_c = elapsed }
        i = i + 1
    }

    bench_result_store(6, iterations, total, min_c, max_c)

    cprint("  VFS open/read/close: ", WHITE_ON_BLACK)
    cprint_decimal(total / iterations, GREEN_ON_BLACK)
    cprint(" cyc/op avg", WHITE_ON_BLACK)
    if fail_count > 0 {
        cprint("  fails=", RED_ON_BLACK)
        cprint_decimal(fail_count, RED_ON_BLACK)
    }
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════════════════════
// Section 9: Master Runner — Run All Benchmarks
// ═══════════════════════════════════════════════════════════════

@kernel fn cmd_bench_all() {
    cprintln("=== FajarOS Benchmark Suite (Sprint 4.6) ===", YELLOW_ON_BLACK)
    cprintln("Running comprehensive benchmarks...", WHITE_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // Clear results
    let mut r: i64 = 0
    while r < BENCH_MAX_RESULTS * BENCH_RESULT_SIZE {
        volatile_write_u8(BENCH_RESULTS + r, 0)
        r = r + 1
    }

    // 1. IPC Latency
    cprintln("[1/7] IPC Latency (1000 iterations):", CYAN_ON_BLACK)
    bench_ipc_latency(1000)
    console_putchar(10, WHITE_ON_BLACK)

    // 2. Context Switch
    cprintln("[2/7] Context Switch (1000 iterations):", CYAN_ON_BLACK)
    bench_ctx_switch(1000)
    console_putchar(10, WHITE_ON_BLACK)

    // 3. Fast IPC vs Normal
    cprintln("[3/7] Fast IPC vs Normal (500 iterations):", CYAN_ON_BLACK)
    bench_fast_vs_normal(500)
    console_putchar(10, WHITE_ON_BLACK)

    // 4. Frame Allocation
    cprintln("[4/7] Frame Alloc/Free (500 iterations):", CYAN_ON_BLACK)
    bench_frame_alloc(500)
    console_putchar(10, WHITE_ON_BLACK)

    // 5. Memory Copy Throughput
    cprintln("[5/7] Memory Copy Throughput:", CYAN_ON_BLACK)
    bench_memcpy_throughput(4096)
    console_putchar(10, WHITE_ON_BLACK)

    // 6. Matmul (multiple sizes)
    cprintln("[6/7] CPU Matmul:", CYAN_ON_BLACK)
    bench_matmul()
    console_putchar(10, WHITE_ON_BLACK)

    // 7. VFS Operations
    cprintln("[7/7] VFS Read (100 iterations):", CYAN_ON_BLACK)
    bench_vfs_read(100)
    console_putchar(10, WHITE_ON_BLACK)

    // ── Summary Table ──
    cprintln("=== Summary Table ===", YELLOW_ON_BLACK)
    cprintln("  Benchmark           Iters    Total     Avg/op    Min/Max     ~Time", WHITE_ON_BLACK)
    cprintln("  -----------------------------------------------------------------------", WHITE_ON_BLACK)
    bench_print_row("IPC latency", 0)
    bench_print_row("Context switch", 1)
    bench_print_row("Fast IPC", 2)
    bench_print_row("Frame alloc", 3)
    bench_print_row("Memcpy", 4)
    bench_print_row("Matmul 32x32", 5)
    bench_print_row("VFS read", 6)
    cprintln("  -----------------------------------------------------------------------", WHITE_ON_BLACK)
    cprintln("  Cycles measured via RDTSC. Time estimates assume 2 GHz.", WHITE_ON_BLACK)
    cprintln("=== Benchmark Complete ===", GREEN_ON_BLACK)
}
