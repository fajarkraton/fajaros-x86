// FajarOS Nova v2.0 — Kernel Test Suite (Sprint 2.6)
// tests/kernel_tests.fj — 20 kernel tests callable from shell
// All functions @kernel annotated. cmd_test_all() runs everything.

const TEST_TOTAL: i64 = 20
const TEST_SCRATCH: i64 = 0x900000  // 4KB scratch area (was 0x8FC000 — overlapped JOURNAL_DATA)

// Bridge stubs for functions that exist in kernel/core/ but not monolithic build
@kernel fn clone_page_table() -> i64 {
    // Simplified: allocate a PML4 and copy entry 0
    let new_pml4 = frame_alloc()
    if new_pml4 == -1 { return -1 }
    let mut i: i64 = 0
    while i < 4096 { volatile_write_u8(new_pml4 + i, 0); i = i + 1 }
    let kernel_entry = page_table_entry(PML4_BASE, 0)
    page_table_set(new_pml4, 0, kernel_entry)
    new_pml4
}
@kernel fn shm_owner_vaddr(region: i64) -> i64 { shm_get_owner_vaddr(region) }
@kernel fn blk_write_sector(dev: i64, lba: i64, buf: i64) -> i64 { blk_svc_raw_write(dev, lba, 1, buf) }
// blk_sync is now defined in services/blk/journal.fj
@kernel fn blk_read_sector(dev: i64, lba: i64, buf: i64) -> i64 { blk_svc_raw_read(dev, lba, 1, buf) }
@kernel fn net_socket_alloc(_proto: i64) -> i64 { sock_alloc() }
@kernel fn net_socket_state(sock: i64) -> i64 { sock_read(sock, 0) }
@kernel fn vfs_read(fd: i64, buf: i64, len: i64) -> i64 {
    // Bridge: VFS read via IPC
    let msg: i64 = 0x901200
    let reply: i64 = 0x901300
    ipc_msg_clear(msg)
    ipc_msg_set_header(msg, 0, MSG_VFS_READ, 0)
    volatile_write_u64(msg + 16, fd)
    volatile_write_u64(msg + 24, 0)
    volatile_write_u64(msg + 32, len)
    ipc_msg_clear(reply)
    vfs_svc_handle_msg(0, msg, reply)
    let bytes = volatile_read_u64(reply + 48)
    let mut i: i64 = 0
    while i < bytes && i < 32 {
        volatile_write_u8(buf + i, volatile_read_u8(reply + 16 + i))
        i = i + 1
    }
    bytes
}
@kernel fn vfs_close(fd: i64) {
    let msg: i64 = 0x901400
    let reply: i64 = 0x901500
    ipc_msg_clear(msg)
    ipc_msg_set_header(msg, 0, MSG_VFS_CLOSE, 0)
    volatile_write_u64(msg + 16, fd)
    ipc_msg_clear(reply)
    vfs_svc_handle_msg(0, msg, reply)
}
@kernel fn vfs_open(path: i64, _flags: i64) -> i64 {
    // Bridge: build VFS IPC message, call handler, return fd
    let msg: i64 = 0x901000
    let reply: i64 = 0x901100
    ipc_msg_clear(msg)
    ipc_msg_set_header(msg, 0, MSG_VFS_OPEN, 0)
    let mut i: i64 = 0
    while i < 39 {
        let ch = volatile_read_u8(path + i)
        volatile_write_u8(msg + 16 + i, ch)
        if ch == 0 { i = 39 } else { i = i + 1 }
    }
    ipc_msg_clear(reply)
    vfs_svc_handle_msg(0, msg, reply)
    volatile_read_u64(reply + 16)
}

@kernel fn test_pass(name: str) {
    cprint("  [PASS] ", GREEN_ON_BLACK)
    cprintln(name, WHITE_ON_BLACK)
}
@kernel fn test_fail(name: str) {
    cprint("  [FAIL] ", RED_ON_BLACK)
    cprintln(name, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════════════════════
// Kernel Core Tests (10)
// ═══════════════════════════════════════════════════════════════

@kernel fn test_frame_alloc_free() -> i64 {
    let addr = frame_alloc()
    if addr == -1 { return 0 }
    let frame = addr / FRAME_SIZE
    if frame_is_used(frame) != 1 { frame_free(addr); return 0 }
    frame_free(addr)
    if frame_is_used(frame) != 0 { return 0 }
    1
}

@kernel fn test_page_map_unmap() -> i64 {
    let virt: i64 = 0x4000000  // 64MB test region
    let phys = frame_alloc()
    if phys == -1 { return 0 }
    map_page(virt, phys, PAGE_PRESENT | PAGE_WRITABLE)
    volatile_write_u64(virt, 0xCAFEBABE)
    let rb = volatile_read_u64(virt)
    unmap_page(virt)
    frame_free(phys)
    if rb == 0xCAFEBABE { 1 } else { 0 }
}

@kernel fn test_heap_alloc_free() -> i64 {
    let ptr = kmalloc(64)
    if ptr == -1 { return 0 }
    let mut i: i64 = 0
    while i < 64 { volatile_write_u8(ptr + i, (i + 0xA0) & 0xFF); i = i + 1 }
    let mut ok: i64 = 1
    i = 0
    while i < 64 {
        if volatile_read_u8(ptr + i) != ((i + 0xA0) & 0xFF) { ok = 0 }
        i = i + 1
    }
    kfree(ptr)
    ok
}

@kernel fn test_slab_alloc_free() -> i64 {
    let ptr = slab_alloc(32)
    if ptr == -1 { return 0 }
    volatile_write_u64(ptr, 0xDEADC0DE)
    volatile_write_u64(ptr + 8, 0x12345678)
    let v0 = volatile_read_u64(ptr)
    let v1 = volatile_read_u64(ptr + 8)
    slab_free(ptr, 32)
    if v0 == 0xDEADC0DE && v1 == 0x12345678 { 1 } else { 0 }
}

@kernel fn test_process_lifecycle() -> i64 {
    let pid = proc_v2_alloc()
    if pid < 0 { return 0 }
    proc_v2_set(pid, 0, PROC_STATE_READY)
    proc_v2_set(pid, 8, pid)
    proc_v2_set(pid, 24, 0x1000)
    if proc_v2_get(pid, 0) != PROC_STATE_READY { proc_v2_set(pid, 0, PROC_STATE_FREE); return 0 }
    proc_v2_exit(pid, 42)
    if proc_v2_get(pid, 0) != PROC_STATE_ZOMBIE { proc_v2_set(pid, 0, PROC_STATE_FREE); return 0 }
    let code = proc_v2_waitpid(0, pid)
    if code != 42 { return 0 }
    if proc_v2_get(pid, 0) == PROC_STATE_FREE { 1 } else { 0 }
}

@kernel fn test_frame_contiguous() -> i64 {
    let addr = frame_alloc_contiguous(4)
    if addr == -1 { return 0 }
    let base = addr / FRAME_SIZE
    let mut ok: i64 = 1
    let mut i: i64 = 0
    while i < 4 { if frame_is_used(base + i) != 1 { ok = 0 }; i = i + 1 }
    i = 0
    while i < 4 { frame_free(addr + i * FRAME_SIZE); i = i + 1 }
    ok
}

@kernel fn test_spinlock() -> i64 {
    let lock_addr = TEST_SCRATCH
    volatile_write_u64(lock_addr, 0)
    spinlock_acquire(lock_addr)
    if volatile_read_u64(lock_addr) != 1 { spinlock_release(lock_addr); return 0 }
    spinlock_release(lock_addr)
    if volatile_read_u64(lock_addr) == 0 { 1 } else { 0 }
}

@kernel fn test_clone_page_table() -> i64 {
    let new_pml4 = clone_page_table()
    if new_pml4 == -1 { return 0 }
    let entry = page_table_entry(new_pml4, 0)
    let ok = if (entry & PAGE_PRESENT) != 0 { 1 } else { 0 }
    frame_free(new_pml4)
    ok
}

@kernel fn test_heap_multi_alloc() -> i64 {
    let p1 = kmalloc(32)
    let p2 = kmalloc(32)
    let p3 = kmalloc(32)
    if p1 == -1 || p2 == -1 || p3 == -1 {
        if p1 != -1 { kfree(p1) }
        if p2 != -1 { kfree(p2) }
        if p3 != -1 { kfree(p3) }
        return 0
    }
    let d12 = if p2 > p1 { p2 - p1 } else { p1 - p2 }
    let d23 = if p3 > p2 { p3 - p2 } else { p2 - p3 }
    let d13 = if p3 > p1 { p3 - p1 } else { p1 - p3 }
    kfree(p1); kfree(p2); kfree(p3)
    if d12 >= 32 && d23 >= 32 && d13 >= 32 { 1 } else { 0 }
}

@kernel fn test_perf_counters() -> i64 {
    perf_reset()
    perf_record_ipc(100)
    perf_record_ipc(200)
    perf_record_ipc(50)
    let count = volatile_read_u64(PERF_BASE + PERF_IPC_COUNT)
    let total = volatile_read_u64(PERF_BASE + PERF_IPC_TOTAL)
    let mn = volatile_read_u64(PERF_BASE + PERF_IPC_MIN)
    let mx = volatile_read_u64(PERF_BASE + PERF_IPC_MAX)
    perf_reset()
    if count == 3 && total == 350 && mn == 50 && mx == 200 { 1 } else { 0 }
}

// ═══════════════════════════════════════════════════════════════
// IPC Tests (5)
// ═══════════════════════════════════════════════════════════════

@kernel fn test_ipc_queue_roundtrip() -> i64 {
    let my_pid = volatile_read_u64(0x6FE00)
    let msg_buf: i64 = TEST_SCRATCH
    let recv_buf: i64 = TEST_SCRATCH + 128
    let sender_out: i64 = TEST_SCRATCH + 256
    let mut total: i64 = 0
    let mut ok: i64 = 1
    while total < 100 && ok == 1 {
        let burst = if (100 - total) < 4 { 100 - total } else { 4 }
        let mut j: i64 = 0
        while j < burst {
            ipc_msg_clear(msg_buf)
            ipc_msg_set_header(msg_buf, my_pid, 0x42, total + j)
            volatile_write_u64(msg_buf + 16, 0xBEEF0000 + total + j)
            if ipc_queue_push(my_pid, my_pid, msg_buf) != IPC_OK { ok = 0 }
            j = j + 1
        }
        j = 0
        while j < burst && ok == 1 {
            if ipc_queue_pop(my_pid, sender_out, recv_buf) != IPC_OK { ok = 0 }
            if volatile_read_u64(recv_buf + 16) != (0xBEEF0000 + total + j) { ok = 0 }
            j = j + 1
        }
        total = total + burst
    }
    ok
}

@kernel fn test_ipc_channel_register() -> i64 {
    let name_buf: i64 = TEST_SCRATCH + 320
    volatile_write_u8(name_buf, 116)      // t
    volatile_write_u8(name_buf + 1, 115)  // s
    volatile_write_u8(name_buf + 2, 116)  // t
    volatile_write_u8(name_buf + 3, 95)   // _
    volatile_write_u8(name_buf + 4, 99)   // c
    volatile_write_u8(name_buf + 5, 104)  // h
    volatile_write_u8(name_buf + 6, 0)
    let reg = channel_register(name_buf, 7)
    if reg < 0 { return 0 }
    let found = channel_lookup(name_buf)
    if found != 7 { channel_unregister(name_buf); return 0 }
    let unreg = channel_unregister(name_buf)
    if unreg < 0 { return 0 }
    if channel_lookup(name_buf) == -2 { 1 } else { 0 }
}

@kernel fn test_ipc_notify_poll() -> i64 {
    let my_pid = volatile_read_u64(0x6FE00)
    ep_write(my_pid, EP_NOTIFY_PENDING, 0)
    ipc2_notify(my_pid, NOTIFY_DATA_READY | NOTIFY_TIMER)
    let pending = ep_read(my_pid, EP_NOTIFY_PENDING)
    if pending != (NOTIFY_DATA_READY | NOTIFY_TIMER) { return 0 }
    let got = ipc2_poll_notify(NOTIFY_DATA_READY)
    if got != NOTIFY_DATA_READY { return 0 }
    let remaining = ep_read(my_pid, EP_NOTIFY_PENDING)
    ipc2_poll_notify(NOTIFY_TIMER)  // cleanup
    if remaining == NOTIFY_TIMER { 1 } else { 0 }
}

@kernel fn test_ipc_shm_create_destroy() -> i64 {
    let region = shm_create(4096)
    if region < 0 { return 0 }
    let vaddr = shm_owner_vaddr(region)
    if vaddr == 0 { shm_destroy(region); return 0 }
    volatile_write_u64(vaddr, 0xABCD1234)
    let rb = volatile_read_u64(vaddr)
    shm_destroy(region)
    let state = volatile_read_u64(SHM_TABLE + region * SHM_ENTRY_SIZE)
    if rb == 0xABCD1234 && state == SHM_FREE { 1 } else { 0 }
}

@kernel fn test_ipc_fast_path() -> i64 {
    fastpath_init()
    let my_pid = volatile_read_u64(0x6FE00)
    let t0 = rdtsc()
    let mut i: i64 = 0
    let mut ok: i64 = 1
    while i < 50 && ok == 1 {
        if ipc_fast_send(my_pid, 0x1111 + i, 0x2222 + i) != 0 { ok = 0 }
        if ipc_fast_recv() < 0 { ok = 0 }
        if ipc_fast_recv_data0() != (0x1111 + i) { ok = 0 }
        if ipc_fast_recv_data1() != (0x2222 + i) { ok = 0 }
        i = i + 1
    }
    let t1 = rdtsc()
    if ok == 1 {
        cprint("    (50 msgs in ", WHITE_ON_BLACK)
        cprint_decimal(t1 - t0, CYAN_ON_BLACK)
        cprintln(" cycles)", WHITE_ON_BLACK)
    }
    ok
}

// ═══════════════════════════════════════════════════════════════
// Service Tests (5)
// ═══════════════════════════════════════════════════════════════

@kernel fn test_vfs_open_read_close() -> i64 {
    let path_buf: i64 = TEST_SCRATCH + 384
    // "/proc/version"
    volatile_write_u8(path_buf, 47)        // /
    volatile_write_u8(path_buf + 1, 112)   // p
    volatile_write_u8(path_buf + 2, 114)   // r
    volatile_write_u8(path_buf + 3, 111)   // o
    volatile_write_u8(path_buf + 4, 99)    // c
    volatile_write_u8(path_buf + 5, 47)    // /
    volatile_write_u8(path_buf + 6, 118)   // v
    volatile_write_u8(path_buf + 7, 101)   // e
    volatile_write_u8(path_buf + 8, 114)   // r
    volatile_write_u8(path_buf + 9, 115)   // s
    volatile_write_u8(path_buf + 10, 105)  // i
    volatile_write_u8(path_buf + 11, 111)  // o
    volatile_write_u8(path_buf + 12, 110)  // n
    volatile_write_u8(path_buf + 13, 0)
    let data_buf: i64 = TEST_SCRATCH + 512
    let fd = vfs_open(path_buf, 0)
    if fd < 0 { return 0 }
    let bytes = vfs_read(fd, data_buf, 64)
    vfs_close(fd)
    if bytes <= 0 { return 0 }
    if volatile_read_u8(data_buf) == 70 { 1 } else { 0 }  // 'F' for "FajarOS"
}

@kernel fn test_blk_ramdisk_rw() -> i64 {
    let write_buf: i64 = TEST_SCRATCH + 1024
    let read_buf: i64 = TEST_SCRATCH + 1536
    let mut i: i64 = 0
    while i < 512 { volatile_write_u8(write_buf + i, (i * 3 + 7) & 0xFF); i = i + 1 }
    if blk_write_sector(0, 99, write_buf) <= 0 { return 0 }
    if blk_read_sector(0, 99, read_buf) <= 0 { return 0 }
    let mut ok: i64 = 1
    i = 0
    while i < 512 {
        if volatile_read_u8(read_buf + i) != volatile_read_u8(write_buf + i) { ok = 0 }
        i = i + 1
    }
    ok
}

@kernel fn test_net_socket_lifecycle() -> i64 {
    let sock = net_socket_alloc(PROTO_TCP)
    if sock < 0 { return 0 }
    // sock_alloc returns free slot — set state to OPEN manually
    sock_write(sock, 0, SOCK_OPEN)
    sock_write(sock, 8, PROTO_TCP)
    let state = net_socket_state(sock)
    if state != SOCK_OPEN { sock_close(sock); return 0 }
    sock_close(sock)
    if net_socket_state(sock) == SOCK_FREE { 1 } else { 0 }
}

@kernel fn test_shell_history() -> i64 {
    shell_hist_init()
    let buf: i64 = TEST_SCRATCH + 2048
    let mut i: i64 = 0
    while i < 5 {
        let ch = 97 + i  // 'a' + i
        volatile_write_u8(buf, ch); volatile_write_u8(buf + 1, ch)
        volatile_write_u8(buf + 2, ch); volatile_write_u8(buf + 3, 0)
        shell_hist_add(buf, 3)
        i = i + 1
    }
    let out_buf: i64 = TEST_SCRATCH + 2112
    let len = shell_hist_get(0, out_buf)
    if len != 3 || volatile_read_u8(out_buf) != 101 { return 0 }  // 'e'
    let len2 = shell_hist_get(1, out_buf)
    if len2 != 3 || volatile_read_u8(out_buf) != 100 { return 0 } // 'd'
    1
}

@kernel fn test_init_service_status() -> i64 {
    let mut ok: i64 = 1
    let mut i: i64 = 0
    while i < 4 {
        if init_svc_get_state(i) != SVC_RUNNING { ok = 0 }
        i = i + 1
    }
    ok
}

// ═══════════════════════════════════════════════════════════════
// Master Test Runner — cmd_test_all()
// ═══════════════════════════════════════════════════════════════

@kernel fn run_test(result: i64, name: str, p: i64, f: i64) -> i64 {
    // Returns packed: high 32 = new_passed, low 32 = new_failed
    if result == 1 { test_pass(name); return (p + 1) * 0x100000000 + f }
    test_fail(name)
    p * 0x100000000 + f + 1
}

@kernel fn cmd_test_all() {
    cprintln("=== FajarOS Kernel Test Suite ===", YELLOW_ON_BLACK)
    cprintln("Running 20 tests...", WHITE_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    let mut p: i64 = 0
    let mut f: i64 = 0

    cprintln("--- Kernel Core ---", CYAN_ON_BLACK)
    let mut r = run_test(test_frame_alloc_free(), "frame_alloc_free", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_page_map_unmap(), "page_map_unmap", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_heap_alloc_free(), "heap_alloc_free", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_slab_alloc_free(), "slab_alloc_free", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_process_lifecycle(), "process_lifecycle", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_frame_contiguous(), "frame_contiguous", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_spinlock(), "spinlock", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_clone_page_table(), "clone_page_table", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_heap_multi_alloc(), "heap_multi_alloc", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_perf_counters(), "perf_counters", p, f)
    p = r / 0x100000000; f = r % 0x100000000

    console_putchar(10, WHITE_ON_BLACK)
    cprintln("--- IPC ---", CYAN_ON_BLACK)
    r = run_test(test_ipc_queue_roundtrip(), "ipc_queue_roundtrip", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_ipc_channel_register(), "ipc_channel_register", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_ipc_notify_poll(), "ipc_notify_poll", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_ipc_shm_create_destroy(), "ipc_shm_create_destroy", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_ipc_fast_path(), "ipc_fast_path", p, f)
    p = r / 0x100000000; f = r % 0x100000000

    console_putchar(10, WHITE_ON_BLACK)
    cprintln("--- Services ---", CYAN_ON_BLACK)
    r = run_test(test_vfs_open_read_close(), "vfs_open_read_close", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_blk_ramdisk_rw(), "blk_ramdisk_rw", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_net_socket_lifecycle(), "net_socket_lifecycle", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_shell_history(), "shell_history", p, f)
    p = r / 0x100000000; f = r % 0x100000000
    r = run_test(test_init_service_status(), "init_service_status", p, f)
    p = r / 0x100000000; f = r % 0x100000000

    console_putchar(10, WHITE_ON_BLACK)
    cprintln("================================", YELLOW_ON_BLACK)
    cprint("Results: ", WHITE_ON_BLACK)
    cprint_decimal(p, GREEN_ON_BLACK)
    cprint("/", WHITE_ON_BLACK)
    cprint_decimal(TEST_TOTAL, WHITE_ON_BLACK)
    cprint(" passed, ", WHITE_ON_BLACK)
    cprint_decimal(f, if f == 0 { GREEN_ON_BLACK } else { RED_ON_BLACK })
    cprintln(" failed", WHITE_ON_BLACK)
    if f == 0 { cprintln("ALL TESTS PASSED", GREEN_ON_BLACK) }
    else { cprintln("SOME TESTS FAILED", RED_ON_BLACK) }
}
