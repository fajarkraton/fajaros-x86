// FajarOS Nova v2.0 — ARM64 Q6A Native Test (runs under Linux)
// Tests microkernel logic on real ARM64 hardware (Kryo 670)

fn arm64_cpuinfo() {
    println("══════════════════════════════════════════")
    println(" FajarOS ARM64 — Radxa Dragon Q6A")
    println("══════════════════════════════════════════")
    println("")
}

// ═══════════════════════════════════════════════════════════════
// Test 1: IPC Message Format
// ═══════════════════════════════════════════════════════════════
fn test_ipc() -> i64 {
    let total = 8 + 4 + 4 + 40 + 8  // src_pid + msg_type + msg_id + payload + reserved
    if total == 64 { 1 } else { 0 }
}

// ═══════════════════════════════════════════════════════════════
// Test 2: Capability Defaults
// ═══════════════════════════════════════════════════════════════
fn test_caps() -> i64 {
    let safe = 1 | 2 | 4 | 512 | 256  // IPC_SEND + RECV + SPAWN + FS + NET = 775
    let device = 1 | 2 | 16 | 32 | 64 | 128 | 1024  // = 1267
    if safe != 775 { return 0 }
    if device != 1267 { return 0 }
    1
}

// ═══════════════════════════════════════════════════════════════
// Test 3: FNV-1a Password Hash (same as auth service)
// ═══════════════════════════════════════════════════════════════
fn fnv1a_hash(s: str) -> i64 {
    let mut hash: i64 = 0x811C9DC5
    let len = len(s)
    let mut i: i64 = 0
    while i < len {
        let byte = to_int(s[i])
        hash = hash ^ byte
        hash = hash * 0x01000193
        hash = hash & 0x7FFFFFFF
        i = i + 1
    }
    hash
}

fn test_hash() -> i64 {
    let h1 = fnv1a_hash("root")
    let h2 = fnv1a_hash("root")
    let h3 = fnv1a_hash("fajar")
    if h1 != h2 { return 0 }  // Same input → same hash
    if h1 == h3 { return 0 }  // Different input → different hash
    1
}

// ═══════════════════════════════════════════════════════════════
// Test 4: TCP State Machine
// ═══════════════════════════════════════════════════════════════
fn test_tcp_states() -> i64 {
    let closed = 0
    let syn_sent = 2
    let established = 4
    let fin_wait = 5
    // SYN → SYN_SENT → ESTABLISHED → FIN_WAIT → CLOSED
    let mut state = closed
    state = syn_sent       // After sending SYN
    if state != 2 { return 0 }
    state = established    // After SYN+ACK received
    if state != 4 { return 0 }
    state = fin_wait       // After sending FIN
    if state != 5 { return 0 }
    state = closed         // After FIN-ACK
    if state != 0 { return 0 }
    1
}

// ═══════════════════════════════════════════════════════════════
// Test 5: Priority Scheduler
// ═══════════════════════════════════════════════════════════════
fn test_scheduler() -> i64 {
    // Priorities: IDLE=0, NORMAL=1, HIGH=2, REALTIME=3
    // Scheduler picks highest priority first
    let mut selected = -1
    let mut prio = 3
    while prio >= 0 {
        if prio == 1 { selected = prio }  // NORMAL process exists
        prio = prio - 1
    }
    if selected == 1 { 1 } else { 0 }
}

// ═══════════════════════════════════════════════════════════════
// Test 6: Matrix Multiply (CPU fallback)
// ═══════════════════════════════════════════════════════════════
fn test_matmul() -> i64 {
    // 2×2 matrix multiply: [[1,2],[3,4]] × [[5,6],[7,8]]
    // Result: [[19,22],[43,50]]
    let a00 = 1; let a01 = 2; let a10 = 3; let a11 = 4
    let b00 = 5; let b01 = 6; let b10 = 7; let b11 = 8
    let c00 = a00*b00 + a01*b10  // 1*5 + 2*7 = 19
    let c01 = a00*b01 + a01*b11  // 1*6 + 2*8 = 22
    let c10 = a10*b00 + a11*b10  // 3*5 + 4*7 = 43
    let c11 = a10*b01 + a11*b11  // 3*6 + 4*8 = 50
    if c00 != 19 || c01 != 22 || c10 != 43 || c11 != 50 { return 0 }
    1
}

// ═══════════════════════════════════════════════════════════════
// Test 7: DNS Cache Hash
// ═══════════════════════════════════════════════════════════════
fn test_dns_hash() -> i64 {
    let h1 = fnv1a_hash("example.com")
    let h2 = fnv1a_hash("google.com")
    if h1 == h2 { return 0 }
    if h1 == 0 { return 0 }
    1
}

// ═══════════════════════════════════════════════════════════════
// Test 8: VFS Path Match (longest prefix)
// ═══════════════════════════════════════════════════════════════
fn test_vfs_path() -> i64 {
    let root = 1; let proc = 5; let dev = 4
    let best = if proc > root && proc > dev { proc } else { root }
    if best == 5 { 1 } else { 0 }
}

// ═══════════════════════════════════════════════════════════════
// Test 9: Fibonacci (JIT performance)
// ═══════════════════════════════════════════════════════════════
fn fib(n: i64) -> i64 {
    if n <= 1 { return n }
    fib(n - 1) + fib(n - 2)
}

fn test_fib() -> i64 {
    if fib(20) == 6765 { 1 } else { 0 }
}

// ═══════════════════════════════════════════════════════════════
// Test 10: Block Cache Round-Robin
// ═══════════════════════════════════════════════════════════════
fn test_cache() -> i64 {
    let entries = 16
    let mut counter = 0
    let mut i = 0
    while i < 100 {
        let slot = counter % entries
        counter = counter + 1
        i = i + 1
    }
    if counter == 100 { 1 } else { 0 }
}

// ═══════════════════════════════════════════════════════════════
// Master Runner
// ═══════════════════════════════════════════════════════════════

fn main() {
    arm64_cpuinfo()
    let mut pass = 0
    let mut fail = 0

    let tests: [str; 10] = [
        "IPC message format (64B)",
        "Capability bits (safe=775, device=1267)",
        "FNV-1a password hash consistency",
        "TCP state machine transitions",
        "Priority scheduler order",
        "Matrix multiply 2x2",
        "DNS cache hash uniqueness",
        "VFS path longest-prefix match",
        "Fibonacci(20) = 6765",
        "Block cache round-robin 100 ops"
    ]
    let results: [i64; 10] = [
        test_ipc(), test_caps(), test_hash(), test_tcp_states(), test_scheduler(),
        test_matmul(), test_dns_hash(), test_vfs_path(), test_fib(), test_cache()
    ]

    let mut i = 0
    while i < 10 {
        if results[i] == 1 {
            println("  [PASS] " + tests[i])
            pass = pass + 1
        } else {
            println("  [FAIL] " + tests[i])
            fail = fail + 1
        }
        i = i + 1
    }

    println("")
    println("══════════════════════════════════════════")
    println("Results: " + to_string(pass) + "/10 passed, " + to_string(fail) + " failed")
    if fail == 0 { println("ALL TESTS PASSED on ARM64 Q6A!") }
    else { println("SOME TESTS FAILED") }
}
