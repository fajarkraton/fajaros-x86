// FajarOS Nova v1.0.0 — Shell Commands
// Part of the modular kernel build (concatenated by Makefile)
// Contains: scancode mapping, command buffer, history,
// all 160+ shell commands (cmd_*), and the command dispatcher.
// Note: VGA console functions (console_init, cprint, etc.) are in drivers/vga.fj

// Note: sc2ascii is in drivers/keyboard.fj, vga_update_cursor is in drivers/vga.fj

// ═══════════════════════════════════════════════
// Command Line Buffer (at 0x6F800, max 64 chars)
// ═══════════════════════════════════════════════

@kernel fn cmdbuf_clear() {
    let mut i: i64 = 0
    while i < 64 { volatile_write_u8(0x6F800 + i, 0); i = i + 1 }
    volatile_write(0x6F880, 0)  // length = 0
}

@kernel fn cmdbuf_push(ch: i64) {
    let len = volatile_read(0x6F880)
    if len < 63 {
        volatile_write_u8(0x6F800 + len, ch)
        volatile_write(0x6F880, len + 1)
    }
}

@kernel fn cmdbuf_pop() {
    let len = volatile_read(0x6F880)
    if len > 0 {
        volatile_write(0x6F880, len - 1)
        volatile_write_u8(0x6F800 + len - 1, 0)
    }
}

@kernel fn cmdbuf_len() -> i64 {
    volatile_read(0x6F880)
}

@kernel fn cmdbuf_match(s: str) -> i64 {
    let slen = str_len(s)
    let clen = cmdbuf_len()
    let mut result: i64 = 1
    if slen != clen {
        result = 0
    }
    let mut i: i64 = 0
    while i < slen && result == 1 {
        let a = volatile_read_u8(0x6F800 + i)
        let b = str_byte_at(s, i)
        if a != b {
            result = 0
        }
        i = i + 1
    }
    result
}


// ═══════════════════════════════════════════════
// Command History (8 slots × 64 bytes at 0x6F900)
// 0x6FC00: history count
// 0x6FC08: history index (for up/down navigation)
// ═══════════════════════════════════════════════

const HIST_BASE: i64 = 0x6F900
const HIST_SLOTS: i64 = 8
const HIST_SLOT_SIZE: i64 = 64

@kernel fn history_init() {
    volatile_write(0x6FC00, 0)  // count = 0
    volatile_write(0x6FC08, -1) // nav index = -1 (not navigating)
}

@kernel fn history_push() {
    let len = cmdbuf_len()
    if len == 0 { return }
    let count = volatile_read(0x6FC00)
    // Shift all entries up if full
    if count >= HIST_SLOTS {
        let mut i: i64 = 0
        while i < HIST_SLOTS - 1 {
            let src = HIST_BASE + (i + 1) * HIST_SLOT_SIZE
            let dst = HIST_BASE + i * HIST_SLOT_SIZE
            let mut j: i64 = 0
            while j < HIST_SLOT_SIZE {
                volatile_write_u8(dst + j, volatile_read_u8(src + j))
                j = j + 1
            }
            i = i + 1
        }
        // Write to last slot
        let slot = HIST_BASE + (HIST_SLOTS - 1) * HIST_SLOT_SIZE
        let mut k: i64 = 0
        while k < len && k < 63 {
            volatile_write_u8(slot + k, volatile_read_u8(0x6F800 + k))
            k = k + 1
        }
        volatile_write_u8(slot + k, 0)
    } else {
        // Write to next slot
        let slot = HIST_BASE + count * HIST_SLOT_SIZE
        let mut k: i64 = 0
        while k < len && k < 63 {
            volatile_write_u8(slot + k, volatile_read_u8(0x6F800 + k))
            k = k + 1
        }
        volatile_write_u8(slot + k, 0)
        volatile_write(0x6FC00, count + 1)
    }
    volatile_write(0x6FC08, -1) // reset nav
}

@kernel fn history_navigate(direction: i64) {
    // direction: -1 = up (older), +1 = down (newer)
    let count = volatile_read(0x6FC00)
    if count == 0 { return }
    let mut idx = volatile_read(0x6FC08)

    if direction == -1 {
        // Up - go to older
        if idx == -1 { idx = count - 1 }
        else if idx > 0 { idx = idx - 1 }
        else { return }
    } else {
        // Down - go to newer
        if idx == -1 { return }
        if idx < count - 1 { idx = idx + 1 }
        else { idx = -1 }
    }
    volatile_write(0x6FC08, idx)

    // Clear current line from VGA
    let old_len = cmdbuf_len()
    let mut i: i64 = 0
    while i < old_len { console_putchar(8, WHITE_ON_BLACK); i = i + 1 }

    // Clear cmdbuf
    cmdbuf_clear()

    if idx >= 0 {
        // Load history entry into cmdbuf and display
        let slot = HIST_BASE + idx * HIST_SLOT_SIZE
        let mut j: i64 = 0
        while volatile_read_u8(slot + j) != 0 && j < 63 {
            let ch = volatile_read_u8(slot + j)
            cmdbuf_push(ch)
            console_putchar(ch, WHITE_ON_BLACK)
            j = j + 1
        }
    }
}


