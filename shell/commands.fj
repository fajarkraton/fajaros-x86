@kernel fn cmd_bench() {
    cprintln("Benchmark:", YELLOW_ON_BLACK)

    // Fibonacci(30) via iteration
    cprint("  fib(30): ", WHITE_ON_BLACK)
    let t0 = rdtsc()
    let mut a: i64 = 0
    let mut b: i64 = 1
    let mut n: i64 = 0
    while n < 30 {
        let tmp = a + b
        a = b
        b = tmp
        n = n + 1
    }
    let t1 = rdtsc()
    cprint_decimal(b, CYAN_ON_BLACK)
    cprint(" (", WHITE_ON_BLACK)
    cprint_decimal(t1 - t0, CYAN_ON_BLACK)
    cprintln(" cycles)", WHITE_ON_BLACK)

    // Memory write bandwidth: write 1MB
    cprint("  1MB write: ", WHITE_ON_BLACK)
    let t2 = rdtsc()
    let mut addr: i64 = 0x500000
    while addr < 0x600000 {
        volatile_write(addr, addr)
        addr = addr + 8
    }
    let t3 = rdtsc()
    cprint_decimal((t3 - t2) / 1000, CYAN_ON_BLACK)
    cprintln("K cycles", WHITE_ON_BLACK)

    // Matmul 4x4
    cprint("  4x4 matmul: ", WHITE_ON_BLACK)
    let t4 = rdtsc()
    let mut mi: i64 = 0
    while mi < 4 {
        let mut mj: i64 = 0
        while mj < 4 {
            let mut s: i64 = 0
            let mut mk: i64 = 0
            while mk < 4 { s = s + (mi + mk) * (mk + mj); mk = mk + 1 }
            volatile_write(0x500300 + (mi * 4 + mj) * 8, s)
            mj = mj + 1
        }
        mi = mi + 1
    }
    let t5 = rdtsc()
    cprint_decimal(t5 - t4, CYAN_ON_BLACK)
    cprintln(" cycles", WHITE_ON_BLACK)
}

@kernel fn cmd_tsc() {
    cprint("TSC: 0x", WHITE_ON_BLACK)
    let tsc = rdtsc()
    cprint_hex(tsc >> 32, 8, CYAN_ON_BLACK)
    cprint_hex(tsc & 0xFFFFFFFF, 8, CYAN_ON_BLACK)
    cprint(" (", WHITE_ON_BLACK)
    cprint_decimal(tsc, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)
}

@kernel fn cmd_cowsay() {
    // Use echo text or default
    let len = cmdbuf_len()
    if len > 7 {
        // cowsay <msg>
        cprint(" ", WHITE_ON_BLACK)
        let msg_len = len - 7
        let mut d: i64 = 0
        while d < msg_len + 2 { console_putchar(95, WHITE_ON_BLACK); d = d + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        cprint("< ", WHITE_ON_BLACK)
        let mut i: i64 = 7
        while i < len {
            console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK)
            i = i + 1
        }
        cprintln(" >", WHITE_ON_BLACK)
        cprint(" ", WHITE_ON_BLACK)
        d = 0
        while d < msg_len + 2 { console_putchar(45, WHITE_ON_BLACK); d = d + 1 }
        console_putchar(10, WHITE_ON_BLACK)
    } else {
        cprintln(" ______________", WHITE_ON_BLACK)
        cprintln("< FajarOS Nova >", WHITE_ON_BLACK)
        cprintln(" --------------", WHITE_ON_BLACK)
    }
    cprintln("        \\   ^__^", WHITE_ON_BLACK)
    cprintln("         \\  (oo)\\_______", WHITE_ON_BLACK)
    cprintln("            (__)\\       )\\/\\", WHITE_ON_BLACK)
    cprintln("                ||----w |", WHITE_ON_BLACK)
    cprintln("                ||     ||", WHITE_ON_BLACK)
}

@kernel fn cmd_fortune() {
    // Use tick counter as pseudo-random
    let ticks = read_timer_ticks()
    let r = ticks % 8
    if r == 0 { cprintln("\"If it compiles in Fajar Lang, it's safe to deploy.\"", CYAN_ON_BLACK) }
    else if r == 1 { cprintln("\"The best OS is the one you wrote yourself.\"", CYAN_ON_BLACK) }
    else if r == 2 { cprintln("\"@kernel + @device + @safe = no bugs.\"", CYAN_ON_BLACK) }
    else if r == 3 { cprintln("\"Nova: a new star rises on x86_64.\"", CYAN_ON_BLACK) }
    else if r == 4 { cprintln("\"Bahasa terbaik untuk embedded ML + OS.\"", CYAN_ON_BLACK) }
    else if r == 5 { cprintln("\"Safety by construction, not by convention.\"", CYAN_ON_BLACK) }
    else if r == 6 { cprintln("\"From bare metal to neural networks, one language.\"", CYAN_ON_BLACK) }
    else { cprintln("\"Written 100% in Fajar Lang — no C, no Rust, no compromise.\"", CYAN_ON_BLACK) }
}

@kernel fn cmd_seq() {
    // seq: print 1 to 10 (or to N if arg given)
    let mut max_n: i64 = 10
    let len = cmdbuf_len()
    if len > 4 {
        // Parse number after "seq "
        let mut n: i64 = 0
        let mut i: i64 = 4
        while i < len {
            let ch = volatile_read_u8(0x6F800 + i)
            if ch >= 48 && ch <= 57 {
                n = n * 10 + (ch - 48)
            }
            i = i + 1
        }
        if n > 0 && n <= 1000 { max_n = n }
    }
    let mut s: i64 = 1
    while s <= max_n {
        cprint_decimal(s, WHITE_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        s = s + 1
    }
}

@kernel fn cmd_hex() {
    // hex <number> → print as hex
    let len = cmdbuf_len()
    if len > 4 {
        let mut n: i64 = 0
        let mut i: i64 = 4
        while i < len {
            let ch = volatile_read_u8(0x6F800 + i)
            if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
            i = i + 1
        }
        cprint("0x", WHITE_ON_BLACK)
        cprint_hex(n, 8, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else {
        cprintln("Usage: hex <number>", YELLOW_ON_BLACK)
    }
}

@kernel fn cmd_ls() {
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let ftype = volatile_read(addr + 48)
        let size = volatile_read(addr + 32)
        // Print type
        if ftype == 2 { cprint("d ", CYAN_ON_BLACK) }
        else { cprint("- ", WHITE_ON_BLACK) }
        // Print size
        cprint_decimal(size, YELLOW_ON_BLACK)
        cprint("\t", WHITE_ON_BLACK)
        // Print name
        let mut j: i64 = 0
        while volatile_read_u8(addr + j) != 0 && j < 31 {
            if ftype == 2 { console_putchar(volatile_read_u8(addr + j), CYAN_ON_BLACK) }
            else { console_putchar(volatile_read_u8(addr + j), WHITE_ON_BLACK) }
            j = j + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
        i = i + 1
    }
    cprint("Total: ", GREEN_ON_BLACK)
    cprint_decimal(count, GREEN_ON_BLACK)
    cprintln(" entries", GREEN_ON_BLACK)
}

@kernel fn cmd_cat() {
    // cat <filename> — prefix "cat " = 4 chars
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: cat <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(4)
    if idx == -1 {
        cprint("cat: file not found: ", RED_ON_BLACK)
        let mut i: i64 = 4
        while i < len { console_putchar(volatile_read_u8(0x6F800 + i), RED_ON_BLACK); i = i + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        return
    }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 || data_ptr == 0 { return }
    let mut i: i64 = 0
    while i < size {
        console_putchar(volatile_read_u8(data_ptr + i), WHITE_ON_BLACK)
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_touch() {
    // touch <filename> — prefix "touch " = 6 chars
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: touch <file>", YELLOW_ON_BLACK); return }
    // Extract name from buffer
    let name_len = len - 6
    let idx = ramfs_find_buf(6)
    if idx != -1 { return } // already exists
    // Create new entry from buffer
    let count = volatile_read(FS_BASE)
    if count >= FS_MAX_FILES { cprintln("touch: filesystem full", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(count)
    let mut i: i64 = 0
    while i < name_len && i < 31 {
        volatile_write_u8(addr + i, volatile_read_u8(0x6F800 + 6 + i))
        i = i + 1
    }
    volatile_write_u8(addr + i, 0)
    volatile_write(addr + 32, 0)  // size = 0
    volatile_write(addr + 40, 0)  // no data
    volatile_write(addr + 48, 1)  // type = file
    volatile_write(FS_BASE, count + 1)
}

@kernel fn cmd_rm() {
    // rm <filename> — prefix "rm " = 3 chars
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: rm <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(3)
    if idx == -1 {
        cprint("rm: not found: ", RED_ON_BLACK)
        let mut i: i64 = 3
        while i < len { console_putchar(volatile_read_u8(0x6F800 + i), RED_ON_BLACK); i = i + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        return
    }
    // Remove by shifting entries down
    let count = volatile_read(FS_BASE)
    let mut i = idx
    while i < count - 1 {
        let src = ramfs_entry_addr(i + 1)
        let dst = ramfs_entry_addr(i)
        let mut j: i64 = 0
        while j < FS_ENTRY_SIZE {
            volatile_write_u8(dst + j, volatile_read_u8(src + j))
            j = j + 1
        }
        i = i + 1
    }
    volatile_write(FS_BASE, count - 1)
    cprintln("removed", GREEN_ON_BLACK)
}

@kernel fn cmd_mkdir() {
    // mkdir <dirname> — prefix "mkdir " = 6 chars
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: mkdir <dir>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(6)
    if idx != -1 { cprintln("mkdir: already exists", RED_ON_BLACK); return }
    let count = volatile_read(FS_BASE)
    if count >= FS_MAX_FILES { cprintln("mkdir: full", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(count)
    let name_len = len - 6
    let mut i: i64 = 0
    while i < name_len && i < 31 {
        volatile_write_u8(addr + i, volatile_read_u8(0x6F800 + 6 + i))
        i = i + 1
    }
    volatile_write_u8(addr + i, 0)
    volatile_write(addr + 32, 0)
    volatile_write(addr + 40, 0)
    volatile_write(addr + 48, 2)  // type = dir
    volatile_write(FS_BASE, count + 1)
}

@kernel fn cmd_pwd() {
    cprintln("/", WHITE_ON_BLACK)
}

@kernel fn cmd_write() {
    // write <file> <text> — "write " = 6 chars, find space for text
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: write <file> <text>", YELLOW_ON_BLACK); return }
    // Find space separator after filename
    let mut sp: i64 = 6
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: write <file> <text>", YELLOW_ON_BLACK); return }
    // Get filename length
    let name_len = sp - 6
    // Find or create file
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < name_len && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 6 + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + name_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 {
        // Create new file
        if count >= FS_MAX_FILES { cprintln("write: full", RED_ON_BLACK); return }
        idx = count
        let addr = ramfs_entry_addr(idx)
        let mut i: i64 = 0
        while i < name_len && i < 31 {
            volatile_write_u8(addr + i, volatile_read_u8(0x6F800 + 6 + i))
            i = i + 1
        }
        volatile_write_u8(addr + i, 0)
        volatile_write(addr + 48, 1)
        volatile_write(FS_BASE, count + 1)
    }
    // Write data
    let data_start = sp + 1
    let data_len = len - data_start
    let addr = ramfs_entry_addr(idx)
    let data_offset = volatile_read(FS_BASE + 8)
    let mut i: i64 = 0
    while i < data_len {
        volatile_write_u8(data_offset + i, volatile_read_u8(0x6F800 + data_start + i))
        i = i + 1
    }
    volatile_write(addr + 32, data_len)
    volatile_write(addr + 40, data_offset)
    volatile_write(FS_BASE + 8, data_offset + data_len)
}

@kernel fn cmd_head() {
    // head <file> — show first 5 lines (or all if less)
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: head <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(5)
    if idx == -1 { cprintln("head: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 || data_ptr == 0 { return }
    let mut lines: i64 = 0
    let mut i: i64 = 0
    while i < size && lines < 5 {
        let ch = volatile_read_u8(data_ptr + i)
        console_putchar(ch, WHITE_ON_BLACK)
        if ch == 10 { lines = lines + 1 }
        i = i + 1
    }
    if i > 0 && volatile_read_u8(data_ptr + i - 1) != 10 {
        console_putchar(10, WHITE_ON_BLACK)
    }
}

