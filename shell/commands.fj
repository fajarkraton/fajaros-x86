@kernel fn cmd_kill() {
    // kill <pid> [signal] — send signal via Sprint 5.4 signal system
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: kill <pid> [signal]", YELLOW_ON_BLACK); return }
    let mut pid: i64 = 0
    let mut i: i64 = 5
    while i < len && volatile_read_u8(0x6F800 + i) != 32 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { pid = pid * 10 + (ch - 48) }
        i = i + 1
    }
    // Parse optional signal number after space
    let mut sig: i64 = SIG_TERM
    if i < len && volatile_read_u8(0x6F800 + i) == 32 {
        sig = 0; i = i + 1
        while i < len {
            let ch = volatile_read_u8(0x6F800 + i)
            if ch >= 48 && ch <= 57 { sig = sig * 10 + (ch - 48) }
            i = i + 1
        }
    }
    if pid == 0 { cprintln("kill: cannot kill PID 0", RED_ON_BLACK); return }
    let result = sig_send(pid, sig)
    if result == 0 {
        cprint("Signal ", GREEN_ON_BLACK); cprint_decimal(sig, CYAN_ON_BLACK)
        cprint(" → PID ", GREEN_ON_BLACK); cprint_decimal(pid, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else { cprintln("kill: failed", RED_ON_BLACK) }
}

