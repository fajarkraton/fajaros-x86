@kernel fn cmd_wait() {
    // wait <pid> — wait/reap child process (Sprint 5.4)
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: wait <pid>", YELLOW_ON_BLACK); return }
    let mut pid: i64 = 0
    let mut i: i64 = 5
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { pid = pid * 10 + (ch - 48) }
        i = i + 1
    }
    let code = sc_wait(pid)
    if code != -1 {
        cprint("PID ", GREEN_ON_BLACK); cprint_decimal(pid, CYAN_ON_BLACK)
        cprint(" exited (", WHITE_ON_BLACK); cprint_decimal(code, CYAN_ON_BLACK)
        cprintln(")", WHITE_ON_BLACK)
    } else {
        cprint("PID ", WHITE_ON_BLACK); cprint_decimal(pid, CYAN_ON_BLACK)
        cprintln(" not zombie (still running or not child)", WHITE_ON_BLACK)
    }
}

@kernel fn cmd_nice() {
    // nice — show/set process priority (simulated)
    cprintln("Priorities:", YELLOW_ON_BLACK)
    cprintln("  PID 0: priority 0 (kernel)", WHITE_ON_BLACK)
    let mut i: i64 = 1
    while i < 16 {
        let base = 0x600000 + i * 256
        if volatile_read(base + 8) != 0 {
            cprint("  PID ", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            cprintln(": priority 20 (normal)", WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

