// ═══════════════════════════════════════════════
// exec / readelf shell commands
// ═══════════════════════════════════════════════

// Called by __sched_exit when user process exits and PID 0 is next.
// Re-enters the shell polling loop (called with clean kernel stack).
@kernel fn fj_exec_exit_handler() {
    volatile_write_u64(0x6FE00, 0)
    cmdbuf_clear()
    cprint("nova> ", GREEN_ON_BLACK)
    // Re-enter shell polling loop (same as kernel_main's main loop)
    let mut running: i64 = 1
    while running == 1 {
        shell_poll_serial()
        // GUI tick (if framebuffer active)
        let gui_fb = fb_state_read(FB_MAPPED)
        if gui_fb != 0 { anim_tick(16); anim_cleanup() }
    }
}

@kernel fn cmd_exec() {
    // exec <file> — execute an ELF binary from ramfs, run in Ring 3
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: exec <file>", YELLOW_ON_BLACK); return }
    // Build path in a scratch buffer from cmdbuf starting at offset 5
    let path_addr: i64 = 0x6FA80
    let mut i: i64 = 0
    while i < len - 5 && i < 63 {
        volatile_write_u8(path_addr + i, volatile_read_u8(0x6F800 + 5 + i))
        i = i + 1
    }
    volatile_write_u8(path_addr + i, 0)
    // Lazy embed: if target is "hello", embed the ELF data now
    if i == 5 && volatile_read_u8(path_addr) == 104 && volatile_read_u8(path_addr + 1) == 101 && volatile_read_u8(path_addr + 4) == 111 {
        ring3_hello_embed()
    }
    let result = sys_exec(path_addr, 0)
    if result != 0 {
        cprint("exec: failed to load '", RED_ON_BLACK)
        let mut j: i64 = 0
        while j < i { console_putchar(volatile_read_u8(path_addr + j), RED_ON_BLACK); j = j + 1 }
        cprintln("'", RED_ON_BLACK)
        return
    }
    // Directly dispatch: read entry + user_rsp from process table
    let pid = volatile_read_u64(0x6FE00)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    let entry = volatile_read(base + 24)
    let user_rsp = volatile_read(base + 32)
    let final_rsp = if user_rsp == 0 { 0x3000000 - 16 } else { user_rsp }
    irq_disable()
    iretq_to_user(entry, final_rsp, 0x202)
    // NOTE: iretq_to_user does not return.
    // SYS_EXIT → __sched_exit → fj_exec_exit_handler (re-enters shell loop)
}

@kernel fn cmd_spawn() {
    // spawn <file> — preemptive: allocate PID, load ELF, set READY
    // Scheduler picks it up on next timer tick
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: spawn <file>", YELLOW_ON_BLACK); return }
    let path_addr: i64 = 0x6FA80
    let mut i: i64 = 0
    while i < len - 6 && i < 63 {
        volatile_write_u8(path_addr + i, volatile_read_u8(0x6F800 + 6 + i))
        i = i + 1
    }
    volatile_write_u8(path_addr + i, 0)
    // Lazy embed for "hello"
    if i == 5 && volatile_read_u8(path_addr) == 104 && volatile_read_u8(path_addr + 1) == 101 && volatile_read_u8(path_addr + 4) == 111 {
        ring3_hello_embed()
    }

    // Allocate a new PID
    let new_pid = proc_v2_alloc()
    if new_pid < 0 { cprintln("spawn: no free PIDs", RED_ON_BLACK); return }

    // Critical section: disable interrupts while current PID is changed
    // (timer ISR must not see partial state)
    irq_disable()

    // Temporarily set current PID to new process so sys_exec targets it
    let saved_pid = volatile_read_u64(0x6FE00)
    volatile_write_u64(0x6FE00, new_pid)

    let result = sys_exec(path_addr, 0)

    // Restore kernel PID
    volatile_write_u64(0x6FE00, saved_pid)

    irq_enable()

    if result != 0 {
        // Fallback: try PROG_REGISTRY (raw code programs from prog_install_all)
        let prog_slot = prog_find(path_addr)
        if prog_slot >= 0 {
            let prog_base = PROG_REGISTRY + prog_slot * PROG_ENTRY_SIZE
            let code_addr = volatile_read_u64(prog_base + 16)
            let proc_base = 0x890000 + new_pid * 256
            // Map user pages for code + stack
            map_page(code_addr, code_addr, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
            map_page(code_addr + 0xF00000, code_addr + 0xF00000, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
            let user_rsp = code_addr + 0xF00FF0
            // Build context frame on kernel stack
            let kstack_top = 0x900000 + new_pid * 16384 + 16384 - 16
            let mut sp = kstack_top
            sp = sp - 8; volatile_write_u64(sp, 0x1B)         // SS
            sp = sp - 8; volatile_write_u64(sp, user_rsp)     // RSP
            sp = sp - 8; volatile_write_u64(sp, 0x202)        // RFLAGS
            sp = sp - 8; volatile_write_u64(sp, 0x23)         // CS
            sp = sp - 8; volatile_write_u64(sp, code_addr)    // RIP
            let mut r: i64 = 0
            while r < 15 { sp = sp - 8; volatile_write_u64(sp, 0); r = r + 1 }
            volatile_write(proc_base + 40, sp)               // kernel_rsp
            volatile_write(proc_base + 32, user_rsp)         // user_rsp
            volatile_write(proc_base + 24, code_addr)        // entry
            volatile_write(proc_base + 48, read_cr3())       // cr3
            volatile_write(proc_base + 160, 0)               // ticks
            volatile_write(proc_base + 0, 1)                 // READY
        } else {
            proc_v2_set(new_pid, 0, PROC_STATE_FREE)
            cprintln("spawn: program not found", RED_ON_BLACK)
            return
        }
    }

    // sys_exec already set state=READY, RSP, CR3, entry
    // Scheduler will pick it up on next timer tick
    cprint("Spawned PID ", GREEN_ON_BLACK)
    cprint_decimal(new_pid, CYAN_ON_BLACK)
    cprintln(" (scheduler will run it)", WHITE_ON_BLACK)
}

@kernel fn cmd_runall() {
    // runall — run all queued programs sequentially via exec
    let count = batch_count()
    if count == 0 { cprintln("No processes queued. Use 'spawn hello' first.", YELLOW_ON_BLACK); return }
    cprint("Running ", WHITE_ON_BLACK)
    cprint_decimal(count, CYAN_ON_BLACK)
    cprintln(" process(es)...", WHITE_ON_BLACK)
    // Use cmdbuf to simulate "exec hello" for each queued slot
    let mut ran: i64 = 0
    let mut slot = batch_dequeue()
    while slot >= 0 {
        ran = ran + 1
        cprint("  Process ", WHITE_ON_BLACK)
        cprint_decimal(ran, CYAN_ON_BLACK)
        cprint(": ", WHITE_ON_BLACK)
        batch_complete(slot)
        // Directly exec — same pattern as cmd_exec
        cmd_exec_hello()
        slot = batch_dequeue()
    }
    cprint("Done: ", GREEN_ON_BLACK)
    cprint_decimal(ran, CYAN_ON_BLACK)
    cprintln(" processes completed", GREEN_ON_BLACK)
}

// Internal: exec the embedded hello program (used by spawn/runall)
@kernel fn cmd_exec_hello() {
    ring3_hello_embed()
    let path_addr: i64 = 0x6FA80
    volatile_write_u8(path_addr, 104); volatile_write_u8(path_addr+1, 101)
    volatile_write_u8(path_addr+2, 108); volatile_write_u8(path_addr+3, 108)
    volatile_write_u8(path_addr+4, 111); volatile_write_u8(path_addr+5, 0)
    let result = sys_exec(path_addr, 0)
    if result != 0 { cprintln("exec failed", RED_ON_BLACK); return }
    let pid = volatile_read_u64(0x6FE00)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    let entry = volatile_read(base + 24)
    let user_rsp = volatile_read(base + 32)
    if user_rsp == 0 { let ur = 0x3000000 - 16; iretq_to_user(entry, ur, 0x202) }
    else { iretq_to_user(entry, user_rsp, 0x202) }
    // SYS_EXIT returns here
    volatile_write_u64(0x6FE00, 0)
}

@kernel fn cmd_readelf() {
    // readelf <file> — display ELF header info from ramfs
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: readelf <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(8)
    if idx == -1 { cprintln("readelf: file not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size < 64 || data_ptr == 0 { cprintln("readelf: file too small for ELF", RED_ON_BLACK); return }
    // Check ELF magic
    let b0 = volatile_read_u8(data_ptr)
    let b1 = volatile_read_u8(data_ptr + 1)
    let b2 = volatile_read_u8(data_ptr + 2)
    let b3 = volatile_read_u8(data_ptr + 3)
    if b0 != 0x7F || b1 != 69 || b2 != 76 || b3 != 70 {
        cprintln("readelf: not an ELF file", RED_ON_BLACK)
        return
    }
    cprintln("ELF Header:", YELLOW_ON_BLACK)
    cprint("  Class:      ", WHITE_ON_BLACK)
    let eclass = volatile_read_u8(data_ptr + 4)
    if eclass == 2 { cprintln("ELF64", CYAN_ON_BLACK) }
    else { cprintln("ELF32", CYAN_ON_BLACK) }
    cprint("  Data:       ", WHITE_ON_BLACK)
    if volatile_read_u8(data_ptr + 5) == 1 { cprintln("Little-endian", CYAN_ON_BLACK) }
    else { cprintln("Big-endian", CYAN_ON_BLACK) }
    cprint("  Type:       ", WHITE_ON_BLACK)
    let etype = volatile_read_u8(data_ptr + 16)
    if etype == 2 { cprintln("EXEC", CYAN_ON_BLACK) }
    else if etype == 3 { cprintln("DYN (shared)", CYAN_ON_BLACK) }
    else { cprint_decimal(etype, CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK) }
    cprint("  Machine:    ", WHITE_ON_BLACK)
    let machine = volatile_read_u8(data_ptr + 18)
    if machine == 0x3E { cprintln("x86_64", CYAN_ON_BLACK) }
    else { cprint_decimal(machine, CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK) }
    cprint("  Entry:      0x", WHITE_ON_BLACK)
    cprint_hex(volatile_read_u64(data_ptr + 24), 16, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  File size:  ", WHITE_ON_BLACK)
    cprint_decimal(size, CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Command Dispatcher
// ═══════════════════════════════════════════════

@kernel fn buf_eq4(a: i64, b: i64, c: i64, d: i64) -> i64 {
    let r0 = volatile_read_u8(0x6F800)
    let r1 = volatile_read_u8(0x6F801)
    let r2 = volatile_read_u8(0x6F802)
    let r3 = volatile_read_u8(0x6F803)
    if r0 == a && r1 == b && r2 == c && r3 == d { 1 } else { 0 }
}

@kernel fn dispatch_command() {
    let len = cmdbuf_len()
    let mut handled: i64 = 0

    // === Original 15 commands ===
    // help (104,101,108,112)
    if len == 4 && buf_eq4(104, 101, 108, 112) == 1 { cmd_help(); handled = 1 }
    // clear (99,108,101,97,114)
    if handled == 0 && len == 5 && buf_eq4(99, 108, 101, 97) == 1 && volatile_read_u8(0x6F804) == 114 { cmd_clear(); handled = 1 }
    // uname (117,110,97,109,101)
    if handled == 0 && len == 5 && buf_eq4(117, 110, 97, 109) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_uname(); handled = 1 }
    // uptime (117,112,116,105,109,101)
    if handled == 0 && len == 6 && buf_eq4(117, 112, 116, 105) == 1 { cmd_uptime(); handled = 1 }
    // cpuinfo
    if handled == 0 && len == 7 && buf_eq4(99, 112, 117, 105) == 1 { cmd_cpuinfo(); handled = 1 }
    // meminfo
    if handled == 0 && len == 7 && buf_eq4(109, 101, 109, 105) == 1 { cmd_meminfo(); handled = 1 }
    // lspci (108,115,112,99,105)
    if handled == 0 && len == 5 && buf_eq4(108, 115, 112, 99) == 1 { cmd_lspci(); handled = 1 }
    // ps (112,115)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 112 && volatile_read_u8(0x6F801) == 115 { cmd_ps(); handled = 1 }
    // reboot
    if handled == 0 && len == 6 && buf_eq4(114, 101, 98, 111) == 1 { cmd_reboot(); handled = 1 }
    // shutdown (115,104,117,116...)
    if handled == 0 && len == 8 && buf_eq4(115, 104, 117, 116) == 1 { cmd_shutdown(); handled = 1 }
    // acpi (97,99,112,105)
    if handled == 0 && len == 4 && buf_eq4(97, 99, 112, 105) == 1 { cmd_acpi(); handled = 1 }
    // tensor (116,101,110,115,111,114)
    if handled == 0 && len == 6 && buf_eq4(116, 101, 110, 115) == 1 { cmd_tensor(); handled = 1 }
    // mnist (109,110,105,115,116)
    if handled == 0 && len == 5 && buf_eq4(109, 110, 105, 115) == 1 { cmd_mnist(); handled = 1 }
    // version (118,101,114,115,105,111,110)
    if handled == 0 && len == 7 && buf_eq4(118, 101, 114, 115) == 1 { cmd_version(); handled = 1 }

    // === New 15 commands ===
    // whoami (119,104,111,97,109,105)
    if handled == 0 && len == 6 && buf_eq4(119, 104, 111, 97) == 1 { cmd_whoami(); handled = 1 }
    // hostname (104,111,115,116...)
    if handled == 0 && len == 8 && buf_eq4(104, 111, 115, 116) == 1 { cmd_hostname(); handled = 1 }
    // arch (97,114,99,104)
    if handled == 0 && len == 4 && buf_eq4(97, 114, 99, 104) == 1 { cmd_arch(); handled = 1 }
    // nproc (110,112,114,111,99)
    if handled == 0 && len == 5 && buf_eq4(110, 112, 114, 111) == 1 { cmd_nproc(); handled = 1 }
    // date (100,97,116,101)
    if handled == 0 && len == 4 && buf_eq4(100, 97, 116, 101) == 1 { cmd_date(); handled = 1 }
    // free (102,114,101,101)
    if handled == 0 && len == 4 && buf_eq4(102, 114, 101, 101) == 1 { cmd_free(); handled = 1 }
    // sysinfo (115,121,115,105...)
    if handled == 0 && len == 7 && buf_eq4(115, 121, 115, 105) == 1 { cmd_sysinfo(); handled = 1 }
    // logo (108,111,103,111)
    if handled == 0 && len == 4 && buf_eq4(108, 111, 103, 111) == 1 { cmd_logo(); handled = 1 }
    // color (99,111,108,111,114)
    if handled == 0 && len == 5 && buf_eq4(99, 111, 108, 111) == 1 { cmd_color(); handled = 1 }
    // about (97,98,111,117,116)
    if handled == 0 && len == 5 && buf_eq4(97, 98, 111, 117) == 1 { cmd_about(); handled = 1 }
    // bench (98,101,110,99,104)
    if handled == 0 && len == 5 && buf_eq4(98, 101, 110, 99) == 1 { cmd_bench(); handled = 1 }
    // tsc (116,115,99)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 116 && volatile_read_u8(0x6F801) == 115 && volatile_read_u8(0x6F802) == 99 { cmd_tsc(); handled = 1 }
    // cowsay (99,111,119,115...) — also matches "cowsay <msg>"
    if handled == 0 && len >= 6 && buf_eq4(99, 111, 119, 115) == 1 { cmd_cowsay(); handled = 1 }
    // fortune (102,111,114,116...)
    if handled == 0 && len == 7 && buf_eq4(102, 111, 114, 116) == 1 { cmd_fortune(); handled = 1 }
    // seq (115,101,113) — also matches "seq N"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 115 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 113 { cmd_seq(); handled = 1 }
    // hex (104,101,120) — "hex N"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 104 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 120 { cmd_hex(); handled = 1 }

    // === File commands (ramfs) ===
    // ls (108,115)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 108 && volatile_read_u8(0x6F801) == 115 { cmd_ls(); handled = 1 }
    // cat (99,97,116) — "cat <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 116 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_cat(); handled = 1 }
    // echo (101,99,104,111) — "echo <text>"
    if handled == 0 && len >= 4 && buf_eq4(101, 99, 104, 111) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_echo(); handled = 1 }
    // touch (116,111,117,99,104) — "touch <file>" (not "touch-ipc")
    if handled == 0 && len >= 5 && buf_eq4(116, 111, 117, 99) == 1 && volatile_read_u8(0x6F804) == 104 && (len == 5 || volatile_read_u8(0x6F805) == 32) { cmd_touch(); handled = 1 }
    // rm (114,109) — "rm <file>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 114 && volatile_read_u8(0x6F801) == 109 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_rm(); handled = 1 }
    // mkdir (109,107,100,105,114) — "mkdir <dir>"
    if handled == 0 && len >= 5 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 107 && volatile_read_u8(0x6F802) == 100 { cmd_mkdir(); handled = 1 }
    // pwd (112,119,100)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 112 && volatile_read_u8(0x6F801) == 119 && volatile_read_u8(0x6F802) == 100 { cmd_pwd(); handled = 1 }
    // write (119,114,105,116,101) — "write <file> <text>" (not "write-ipc")
    if handled == 0 && len >= 5 && buf_eq4(119, 114, 105, 116) == 1 && volatile_read_u8(0x6F804) == 101 && (len == 5 || volatile_read_u8(0x6F805) == 32) { cmd_write(); handled = 1 }
    // head (104,101,97,100) — "head <file>"
    if handled == 0 && len >= 4 && buf_eq4(104, 101, 97, 100) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_head(); handled = 1 }
    // wc (119,99) — "wc <file>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 119 && volatile_read_u8(0x6F801) == 99 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_wc(); handled = 1 }
    // stat (115,116,97,116) — "stat <file>"
    if handled == 0 && len >= 4 && buf_eq4(115, 116, 97, 116) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_stat(); handled = 1 }

    // === More utility commands ===
    // kill (107,105,108,108) — "kill <pid>"
    if handled == 0 && len >= 4 && buf_eq4(107, 105, 108, 108) == 1 { cmd_kill(); handled = 1 }
    // dmesg (100,109,101,115,103)
    if handled == 0 && len == 5 && buf_eq4(100, 109, 101, 115) == 1 { cmd_dmesg(); handled = 1 }
    // cal (99,97,108)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 108 { cmd_cal(); handled = 1 }
    // sleep (115,108,101,101,112) — "sleep <N>"
    if handled == 0 && len >= 5 && buf_eq4(115, 108, 101, 101) == 1 && volatile_read_u8(0x6F804) == 112 { cmd_sleep(); handled = 1 }
    // true (116,114,117,101)
    if handled == 0 && len == 4 && buf_eq4(116, 114, 117, 101) == 1 { cmd_true(); handled = 1 }
    // false (102,97,108,115,101)
    if handled == 0 && len == 5 && buf_eq4(102, 97, 108, 115) == 1 { cmd_false(); handled = 1 }
    // id (105,100)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 105 && volatile_read_u8(0x6F801) == 100 { cmd_id(); handled = 1 }
    // dice (100,105,99,101)
    if handled == 0 && len == 4 && buf_eq4(100, 105, 99, 101) == 1 { cmd_dice(); handled = 1 }
    // rev (114,101,118) — "rev <text>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 114 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 118 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_rev(); handled = 1 }
    // yes (121,101,115)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 121 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 115 { cmd_yes(); handled = 1 }
    // env (101,110,118)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 101 && volatile_read_u8(0x6F801) == 110 && volatile_read_u8(0x6F802) == 118 { cmd_env(); handled = 1 }

    // === Phase 4 commands (60 total) ===
    // history (104,105,115,116,111,114,121)
    if handled == 0 && len == 7 && buf_eq4(104, 105, 115, 116) == 1 && volatile_read_u8(0x6F804) == 111 { cmd_history(); handled = 1 }
    // xxd (120,120,100) — "xxd <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 120 && volatile_read_u8(0x6F801) == 120 && volatile_read_u8(0x6F802) == 100 { cmd_xxd(); handled = 1 }
    // top (116,111,112)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 116 && volatile_read_u8(0x6F801) == 111 && volatile_read_u8(0x6F802) == 112 { cmd_top(); handled = 1 }
    // append (97,112,112,101,110,100) — "append <file> <text>"
    if handled == 0 && len >= 6 && buf_eq4(97, 112, 112, 101) == 1 && volatile_read_u8(0x6F804) == 110 { cmd_append(); handled = 1 }
    // cp (99,112) — "cp <src> <dst>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 112 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_cp(); handled = 1 }
    // time (116,105,109,101)
    if handled == 0 && len == 4 && buf_eq4(116, 105, 109, 101) == 1 { cmd_time(); handled = 1 }
    // factor (102,97,99,116,111,114) — "factor <N>"
    if handled == 0 && len >= 6 && buf_eq4(102, 97, 99, 116) == 1 && volatile_read_u8(0x6F804) == 111 { cmd_factor(); handled = 1 }
    // prime (112,114,105,109,101) — "prime <N>"
    if handled == 0 && len >= 5 && buf_eq4(112, 114, 105, 109) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_prime(); handled = 1 }

    // === Phase 5 commands (75 total) ===
    // mv (109,118) — "mv <src> <dst>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 118 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_mv(); handled = 1 }
    // tail (116,97,105,108) — "tail <file>"
    if handled == 0 && len >= 4 && buf_eq4(116, 97, 105, 108) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_tail(); handled = 1 }
    // grep (103,114,101,112) — "grep <pat> <file>"
    if handled == 0 && len >= 4 && buf_eq4(103, 114, 101, 112) == 1 { cmd_grep(); handled = 1 }
    // df (100,102)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 100 && volatile_read_u8(0x6F801) == 102 { cmd_df(); handled = 1 }
    // du (100,117)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 100 && volatile_read_u8(0x6F801) == 117 { cmd_du(); handled = 1 }
    // which (119,104,105,99,104) — "which <cmd>"
    if handled == 0 && len >= 5 && buf_eq4(119, 104, 105, 99) == 1 && volatile_read_u8(0x6F804) == 104 { cmd_which(); handled = 1 }
    // type (handled via "type" — but conflicts with "time" prefix check buf_eq4)
    // man (109,97,110) — "man <cmd>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 110 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_man(); handled = 1 }
    // banner (98,97,110,110,101,114) — "banner <text>"
    if handled == 0 && len >= 6 && buf_eq4(98, 97, 110, 110) == 1 { cmd_banner(); handled = 1 }
    // fib (102,105,98) — "fib <N>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 102 && volatile_read_u8(0x6F801) == 105 && volatile_read_u8(0x6F802) == 98 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_fib(); handled = 1 }
    // count
    if handled == 0 && len == 5 && buf_eq4(99, 111, 117, 110) == 1 { cmd_count(); handled = 1 }
    // upcase (117,112,99,97,115,101) — "upcase <text>"
    if handled == 0 && len >= 6 && buf_eq4(117, 112, 99, 97) == 1 { cmd_upcase(); handled = 1 }
    // downcase (100,111,119,110,...) — "downcase <text>"
    if handled == 0 && len >= 8 && buf_eq4(100, 111, 119, 110) == 1 { cmd_downcase(); handled = 1 }
    // cls (99,108,115)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 108 && volatile_read_u8(0x6F802) == 115 { cmd_cls(); handled = 1 }
    // exit (101,120,105,116)
    if handled == 0 && len == 4 && buf_eq4(101, 120, 105, 116) == 1 { cmd_exit(); handled = 1 }

    // === Phase 6 commands ===
    // calc (99,97,108,99) — "calc <a> <op> <b>"
    if handled == 0 && len >= 4 && buf_eq4(99, 97, 108, 99) == 1 { cmd_calc(); handled = 1 }
    // base (98,97,115,101) — "base <N> <radix>"
    if handled == 0 && len >= 4 && buf_eq4(98, 97, 115, 101) == 1 { cmd_base(); handled = 1 }
    // nl (110,108) — "nl <file>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 110 && volatile_read_u8(0x6F801) == 108 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_nl(); handled = 1 }
    // strings (115,116,114,105,...) — "strings <file>"
    if handled == 0 && len >= 7 && buf_eq4(115, 116, 114, 105) == 1 && volatile_read_u8(0x6F804) == 110 && volatile_read_u8(0x6F805) == 103 { cmd_strings(); handled = 1 }
    // len (108,101,110) — "len <text>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 108 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 110 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_len(); handled = 1 }

    // === Phase 7 commands (100 total) ===
    // sort (115,111,114,116) — "sort <file>"
    if handled == 0 && len >= 4 && buf_eq4(115, 111, 114, 116) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_sort(); handled = 1 }
    // uniq (117,110,105,113) — "uniq <file>"
    if handled == 0 && len >= 4 && buf_eq4(117, 110, 105, 113) == 1 { cmd_uniq(); handled = 1 }
    // tr (116,114) — "tr <a> <b> [text]"
    if handled == 0 && len >= 5 && volatile_read_u8(0x6F800) == 116 && volatile_read_u8(0x6F801) == 114 && volatile_read_u8(0x6F802) == 32 { cmd_tr(); handled = 1 }
    // cut (99,117,116) — "cut <n> <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 117 && volatile_read_u8(0x6F802) == 116 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_cut(); handled = 1 }
    // rmdir (114,109,100,105,114) — "rmdir <dir>"
    if handled == 0 && len >= 5 && buf_eq4(114, 109, 100, 105) == 1 && volatile_read_u8(0x6F804) == 114 { cmd_rmdir(); handled = 1 }
    // printenv (112,114,105,110,116,101,110,118) — "printenv [VAR]"
    if handled == 0 && len >= 8 && buf_eq4(112, 114, 105, 110) == 1 && volatile_read_u8(0x6F804) == 116 && volatile_read_u8(0x6F805) == 101 { cmd_printenv(); handled = 1 }
    // set (115,101,116)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 115 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 116 { cmd_set(); handled = 1 }
    // dd (100,100)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 100 && volatile_read_u8(0x6F801) == 100 { cmd_dd(); handled = 1 }
    // md5 (109,100,53) — "md5 <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 100 && volatile_read_u8(0x6F802) == 53 { cmd_md5(); handled = 1 }
    // repeat (114,101,112,101,97,116) — "repeat <n> <text>"
