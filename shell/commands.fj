    let mut a: i64 = 0
    let mut b: i64 = 1
    let mut n: i64 = 0
    while n < 20 { let tmp = a + b; a = b; b = tmp; n = n + 1 }
    cprint_decimal(b, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  factors(360) = ", WHITE_ON_BLACK)
    let mut val: i64 = 360
    let mut d: i64 = 2
    while d * d <= val {
        while val % d == 0 { cprint_decimal(d, CYAN_ON_BLACK); cprint(" ", WHITE_ON_BLACK); val = val / d }
        d = d + 1
    }
    if val > 1 { cprint_decimal(val, CYAN_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
}

