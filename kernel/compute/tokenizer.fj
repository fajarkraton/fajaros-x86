// FajarOS — Kernel Tokenizer (Phase 4)
// BPE tokenizer for LLM inference, runs in @kernel context.
//
// Two modes:
//   1. Byte-level (built-in, 256 entries, zero memory, always works)
//   2. BPE (loaded from .fjt file, greedy longest-match)
//
// All operations: @kernel safe — no heap, no float.
// Paper: "FajarQuant: Hardware-Aware Adaptive Vector Quantization"
//        Putranto (2026), PrimeCore.id
//
// Memory layout:
//   0x830000  TOK_META         Tokenizer metadata (64 bytes)
//   0x830040  TOK_FIRST_BYTE   First-byte index (256 x 8B = 2KB)
//   0x830840  TOK_SCRATCH      Encode/decode scratch (4KB)
//   Dynamic   TOK_TABLE        BPE token table (allocated via frame_alloc_contiguous)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

const TOK_META: i64 = 0x830000
const TOK_FIRST_BYTE: i64 = 0x830040
const TOK_SCRATCH: i64 = 0x830840
const TOK_SCRATCH_SIZE: i64 = 4096

// Metadata offsets (at TOK_META)
const TOK_M_MODE: i64 = 0         // 0=byte, 1=bpe
const TOK_M_VOCAB: i64 = 8        // vocab size
const TOK_M_TABLE_ADDR: i64 = 16  // BPE table base address (frame-allocated)
const TOK_M_TABLE_FRAMES: i64 = 24 // number of frames allocated for table
const TOK_M_MAX_LEN: i64 = 32     // max token byte length
const TOK_M_ENCODED: i64 = 40     // total tokens encoded (counter)
const TOK_M_DECODED: i64 = 48     // total tokens decoded (counter)

// Token entry size (for BPE table)
// Entry: [len(1B) + bytes(15B)] = 16 bytes per entry
const TOK_ENTRY_SIZE: i64 = 16
const TOK_ENTRY_MAX_BYTES: i64 = 15

// First-byte index: 256 entries x 8 bytes
// Each entry: packed (start:32 | count:32) — start index and count in sorted table
const TOK_FBI_ENTRIES: i64 = 256

// .fjt file format
const FJT_MAGIC: i64 = 0x31544A46  // "FJT1" little-endian
const FJT_HEADER_SIZE: i64 = 32

// ═══════════════════════════════════════════════════════════════
// Init — default to byte-level mode
// ═══════════════════════════════════════════════════════════════

@kernel fn tok_init() {
    volatile_write_u64(TOK_META + TOK_M_MODE, 0)       // byte-level
    volatile_write_u64(TOK_META + TOK_M_VOCAB, 256)     // 256 byte tokens
    volatile_write_u64(TOK_META + TOK_M_TABLE_ADDR, 0)  // no table
    volatile_write_u64(TOK_META + TOK_M_TABLE_FRAMES, 0)
    volatile_write_u64(TOK_META + TOK_M_MAX_LEN, 1)     // 1 byte per token
    volatile_write_u64(TOK_META + TOK_M_ENCODED, 0)
    volatile_write_u64(TOK_META + TOK_M_DECODED, 0)

    // Clear first-byte index
    let mut i: i64 = 0
    while i < TOK_FBI_ENTRIES {
        volatile_write_u64(TOK_FIRST_BYTE + i * 8, 0)
        i = i + 1
    }
}

// ═══════════════════════════════════════════════════════════════
// Byte-Level Tokenizer (built-in)
// ═══════════════════════════════════════════════════════════════

// Max tokens per encode call (prevents buffer overflow)
const TOK_MAX_OUTPUT: i64 = 2048

// Encode text at text_addr (text_len bytes) into token IDs at out_addr
// Returns: number of tokens written (capped at TOK_MAX_OUTPUT)
@kernel fn tok_encode(text_addr: i64, text_len: i64, out_addr: i64) -> i64 {
    let mode = volatile_read_u64(TOK_META + TOK_M_MODE)
    if mode == 1 {
        return tok_encode_bpe(text_addr, text_len, out_addr)
    }
    // Byte-level: each byte is a token
    let limit = if text_len > TOK_MAX_OUTPUT { TOK_MAX_OUTPUT } else { text_len }
    let mut i: i64 = 0
    while i < limit {
        let byte_val = volatile_read_u8(text_addr + i)
        volatile_write_u64(out_addr + i * 8, byte_val)
        i = i + 1
    }
    // Update counter
    let prev = volatile_read_u64(TOK_META + TOK_M_ENCODED)
    volatile_write_u64(TOK_META + TOK_M_ENCODED, prev + limit)
    limit
}

// Decode token_id to bytes at out_addr, returns byte length
@kernel fn tok_decode(token_id: i64, out_addr: i64) -> i64 {
    let mode = volatile_read_u64(TOK_META + TOK_M_MODE)
    if mode == 1 {
        return tok_decode_bpe(token_id, out_addr)
    }
    // Byte-level: token ID IS the byte value
    if token_id < 0 || token_id > 255 { return 0 }
    volatile_write_u8(out_addr, token_id)
    let prev = volatile_read_u64(TOK_META + TOK_M_DECODED)
    volatile_write_u64(TOK_META + TOK_M_DECODED, prev + 1)
    1
}

// ═══════════════════════════════════════════════════════════════
// BPE Tokenizer (loaded from .fjt file)
// ═══════════════════════════════════════════════════════════════

// Load BPE token table from RamFS file
// .fjt format: header (32B) + entries (16B each, sorted by first byte then length desc)
// Returns: 0=success, negative=error
@kernel fn tok_load_fjt(prefix_len: i64) -> i64 {
    let file_idx = ramfs_find_buf(prefix_len)
    if file_idx < 0 { return -1 }

    let entry_addr = ramfs_entry_addr(file_idx)
    let file_size = volatile_read(entry_addr + 32)
    let data_ptr = volatile_read(entry_addr + 40)

    if file_size < FJT_HEADER_SIZE { return -4 }

    // Parse header
    let magic = mdl_read_u32(data_ptr)
    if magic != FJT_MAGIC { return -1 }

    let version = mdl_read_u32(data_ptr + 4)
    if version != 1 { return -2 }

    let vocab_size = mdl_read_u32(data_ptr + 8)
    let max_token_len = mdl_read_u32(data_ptr + 12)

    if vocab_size <= 0 || vocab_size > 65536 { return -3 }
    if max_token_len <= 0 || max_token_len > TOK_ENTRY_MAX_BYTES { return -3 }

    // Allocate frames for token table
    let table_bytes = vocab_size * TOK_ENTRY_SIZE
    let n_frames = (table_bytes + 4095) / 4096
    let table_addr = frame_alloc_contiguous(n_frames)
    if table_addr == -1 { return -5 }

    // Copy token entries from file to allocated frames
    let entries_src = data_ptr + FJT_HEADER_SIZE
    mdl_memcpy(table_addr, entries_src, table_bytes)

    // Build first-byte index
    tok_build_fbi(table_addr, vocab_size)

    // Update metadata
    volatile_write_u64(TOK_META + TOK_M_MODE, 1)
    volatile_write_u64(TOK_META + TOK_M_VOCAB, vocab_size)
    volatile_write_u64(TOK_META + TOK_M_TABLE_ADDR, table_addr)
    volatile_write_u64(TOK_META + TOK_M_TABLE_FRAMES, n_frames)
    volatile_write_u64(TOK_META + TOK_M_MAX_LEN, max_token_len)

    0
}

// Build first-byte index from sorted token table
// Entries must be sorted by first byte, then by length descending
@kernel fn tok_build_fbi(table_addr: i64, vocab_size: i64) {
    // Clear index
    let mut i: i64 = 0
    while i < TOK_FBI_ENTRIES {
        volatile_write_u64(TOK_FIRST_BYTE + i * 8, 0)
        i = i + 1
    }

    // Scan entries and record start/count for each first byte
    let mut prev_byte: i64 = -1
    let mut start: i64 = 0
    let mut count: i64 = 0
    i = 0
    while i < vocab_size {
        let entry = table_addr + i * TOK_ENTRY_SIZE
        let first_byte = volatile_read_u8(entry + 1)  // bytes start at offset 1

        if first_byte != prev_byte {
            // Store previous group
            if prev_byte >= 0 {
                let packed = (start << 32) | count
                volatile_write_u64(TOK_FIRST_BYTE + prev_byte * 8, packed)
            }
            prev_byte = first_byte
            start = i
            count = 1
        } else {
            count = count + 1
        }
        i = i + 1
    }
    // Store last group
    if prev_byte >= 0 {
        let packed = (start << 32) | count
        volatile_write_u64(TOK_FIRST_BYTE + prev_byte * 8, packed)
    }
}

// BPE encode: greedy longest-match
@kernel fn tok_encode_bpe(text_addr: i64, text_len: i64, out_addr: i64) -> i64 {
    let table_addr = volatile_read_u64(TOK_META + TOK_M_TABLE_ADDR)
    let max_len = volatile_read_u64(TOK_META + TOK_M_MAX_LEN)
    let mut pos: i64 = 0
    let mut n_tokens: i64 = 0

    while pos < text_len && n_tokens < TOK_MAX_OUTPUT {
        let first_byte = volatile_read_u8(text_addr + pos)

        // Look up first-byte index
        let packed = volatile_read_u64(TOK_FIRST_BYTE + first_byte * 8)
        let fb_start = (packed >> 32) & 0xFFFFFFFF
        let fb_count = packed & 0xFFFFFFFF

        let mut best_id: i64 = -1
        let mut best_len: i64 = 0

        // Search entries for this first byte (sorted longest first)
        let mut j: i64 = 0
        while j < fb_count {
            let entry = table_addr + (fb_start + j) * TOK_ENTRY_SIZE
            let tok_len = volatile_read_u8(entry)  // length at offset 0
            let remaining = text_len - pos

            if tok_len <= remaining && tok_len > best_len {
                // Try to match
                let mut match_ok: i64 = 1
                let mut k: i64 = 0
                while k < tok_len && match_ok == 1 {
                    if volatile_read_u8(entry + 1 + k) != volatile_read_u8(text_addr + pos + k) {
                        match_ok = 0
                    }
                    k = k + 1
                }
                if match_ok == 1 {
                    best_id = fb_start + j
                    best_len = tok_len
                    j = fb_count  // found longest match, stop
                }
            }
            j = j + 1
        }

        if best_id >= 0 {
            volatile_write_u64(out_addr + n_tokens * 8, best_id)
            pos = pos + best_len
        } else {
            // Fallback: emit byte token (first 256 IDs are byte-level)
            volatile_write_u64(out_addr + n_tokens * 8, first_byte)
            pos = pos + 1
        }
        n_tokens = n_tokens + 1
    }

    let prev = volatile_read_u64(TOK_META + TOK_M_ENCODED)
    volatile_write_u64(TOK_META + TOK_M_ENCODED, prev + n_tokens)
    n_tokens
}

// BPE decode: lookup token bytes
@kernel fn tok_decode_bpe(token_id: i64, out_addr: i64) -> i64 {
    let table_addr = volatile_read_u64(TOK_META + TOK_M_TABLE_ADDR)
    let vocab_size = volatile_read_u64(TOK_META + TOK_M_VOCAB)

    if token_id < 0 || token_id >= vocab_size { return 0 }

    let entry = table_addr + token_id * TOK_ENTRY_SIZE
    let tok_len = volatile_read_u8(entry)

    let mut i: i64 = 0
    while i < tok_len {
        volatile_write_u8(out_addr + i, volatile_read_u8(entry + 1 + i))
        i = i + 1
    }

    let prev = volatile_read_u64(TOK_META + TOK_M_DECODED)
    volatile_write_u64(TOK_META + TOK_M_DECODED, prev + 1)
    tok_len
}

// ═══════════════════════════════════════════════════════════════
// Test Tokenizer (built-in BPE test with small vocab)
// ═══════════════════════════════════════════════════════════════

// Create a small test .fjt with common English tokens + byte-level fallback
// Vocab: 256 byte tokens + ~50 common word tokens = 306 entries
@kernel fn tok_create_test() {
    let vocab_size: i64 = 306  // 256 bytes + 50 words
    let max_token_len: i64 = 10
    let table_bytes = vocab_size * TOK_ENTRY_SIZE
    let total_size = FJT_HEADER_SIZE + table_bytes

    // Write to scratch buffer
    let buf: i64 = TOK_SCRATCH

    // Header
    mdl_write_u32(buf, FJT_MAGIC)
    mdl_write_u32(buf + 4, 1)  // version
    mdl_write_u32(buf + 8, vocab_size)
    mdl_write_u32(buf + 12, max_token_len)
    // Reserved
    mdl_write_u32(buf + 16, 0)
    mdl_write_u32(buf + 20, 0)
    mdl_write_u32(buf + 24, 0)
    mdl_write_u32(buf + 28, 0)

    let entries = buf + FJT_HEADER_SIZE

    // First 256 entries: byte-level (sorted by first byte = identity)
    let mut i: i64 = 0
    while i < 256 {
        let e = entries + i * TOK_ENTRY_SIZE
        volatile_write_u8(e, 1)       // length = 1
        volatile_write_u8(e + 1, i)   // byte value = token ID
        // Zero-pad rest
        let mut j: i64 = 2
        while j < TOK_ENTRY_SIZE { volatile_write_u8(e + j, 0); j = j + 1 }
        i = i + 1
    }

    // Add common word tokens (IDs 256+)
    // These are stored after the byte entries
    // tok_add_word(entries, id, bytes...)
    tok_add_entry(entries, 256, 32, 116, 104, 101, 0, 0)     // " the"
    tok_add_entry(entries, 257, 32, 97, 110, 100, 0, 0)      // " and"
    tok_add_entry(entries, 258, 32, 111, 102, 0, 0, 0)       // " of"
    tok_add_entry(entries, 259, 32, 116, 111, 0, 0, 0)       // " to"
    tok_add_entry(entries, 260, 32, 105, 110, 0, 0, 0)       // " in"
    tok_add_entry(entries, 261, 32, 105, 115, 0, 0, 0)       // " is"
    tok_add_entry(entries, 262, 104, 101, 108, 108, 111, 0)  // "hello"
    tok_add_entry(entries, 263, 119, 111, 114, 108, 100, 0)  // "world"
    tok_add_entry(entries, 264, 116, 104, 101, 0, 0, 0)      // "the"
    tok_add_entry(entries, 265, 105, 110, 103, 0, 0, 0)      // "ing"
    tok_add_entry(entries, 266, 116, 105, 111, 110, 0, 0)    // "tion"
    tok_add_entry(entries, 267, 32, 97, 0, 0, 0, 0)          // " a"
    tok_add_entry(entries, 268, 101, 114, 0, 0, 0, 0)        // "er"
    tok_add_entry(entries, 269, 101, 100, 0, 0, 0, 0)        // "ed"
    tok_add_entry(entries, 270, 101, 115, 0, 0, 0, 0)        // "es"
    tok_add_entry(entries, 271, 116, 104, 0, 0, 0, 0)        // "th"
    tok_add_entry(entries, 272, 97, 110, 0, 0, 0, 0)         // "an"
    tok_add_entry(entries, 273, 105, 110, 0, 0, 0, 0)        // "in"
    tok_add_entry(entries, 274, 111, 110, 0, 0, 0, 0)        // "on"
    tok_add_entry(entries, 275, 114, 101, 0, 0, 0, 0)        // "re"
    tok_add_entry(entries, 276, 32, 102, 111, 114, 0, 0)     // " for"
    tok_add_entry(entries, 277, 32, 119, 105, 116, 104, 0)   // " with"
    tok_add_entry(entries, 278, 32, 116, 104, 97, 116, 0)    // " that"
    tok_add_entry(entries, 279, 32, 116, 104, 105, 115, 0)   // " this"
    tok_add_entry(entries, 280, 32, 110, 111, 116, 0, 0)     // " not"
    tok_add_entry(entries, 281, 32, 98, 117, 116, 0, 0)      // " but"
    tok_add_entry(entries, 282, 32, 97, 114, 101, 0, 0)      // " are"
    tok_add_entry(entries, 283, 32, 119, 97, 115, 0, 0)      // " was"
    tok_add_entry(entries, 284, 32, 104, 97, 118, 101, 0)    // " have"
    tok_add_entry(entries, 285, 32, 102, 114, 111, 109, 0)   // " from"
    tok_add_entry(entries, 286, 32, 98, 101, 0, 0, 0)        // " be"
    tok_add_entry(entries, 287, 32, 97, 116, 0, 0, 0)        // " at"
    tok_add_entry(entries, 288, 32, 111, 114, 0, 0, 0)       // " or"
    tok_add_entry(entries, 289, 32, 98, 121, 0, 0, 0)        // " by"
    tok_add_entry(entries, 290, 32, 105, 116, 0, 0, 0)       // " it"
    tok_add_entry(entries, 291, 32, 111, 110, 0, 0, 0)       // " on"
    tok_add_entry(entries, 292, 32, 121, 111, 117, 0, 0)     // " you"
    tok_add_entry(entries, 293, 32, 99, 97, 110, 0, 0)       // " can"
    tok_add_entry(entries, 294, 32, 119, 101, 0, 0, 0)       // " we"
    tok_add_entry(entries, 295, 32, 104, 101, 0, 0, 0)       // " he"
    tok_add_entry(entries, 296, 32, 115, 104, 101, 0, 0)     // " she"
    tok_add_entry(entries, 297, 32, 100, 111, 0, 0, 0)       // " do"
    tok_add_entry(entries, 298, 32, 109, 121, 0, 0, 0)       // " my"
    tok_add_entry(entries, 299, 32, 110, 111, 0, 0, 0)       // " no"
    tok_add_entry(entries, 300, 32, 115, 111, 0, 0, 0)       // " so"
    tok_add_entry(entries, 301, 32, 117, 112, 0, 0, 0)       // " up"
    tok_add_entry(entries, 302, 32, 105, 102, 0, 0, 0)       // " if"
    tok_add_entry(entries, 303, 32, 109, 101, 0, 0, 0)       // " me"
    tok_add_entry(entries, 304, 32, 104, 105, 115, 0, 0)     // " his"
    tok_add_entry(entries, 305, 32, 104, 101, 114, 0, 0)     // " her"

    // Save to RamFS
    ramfs_write_at_addr("test.fjt", buf, total_size)
}

// Helper: write a token entry (up to 6 bytes specified, auto-calculates length)
@kernel fn tok_add_entry(entries: i64, id: i64, b0: i64, b1: i64, b2: i64, b3: i64, b4: i64, b5: i64) {
    let e = entries + id * TOK_ENTRY_SIZE
    // Count non-zero bytes
    let mut len: i64 = 0
    if b0 != 0 { len = 1 }
    if b1 != 0 { len = 2 }
    if b2 != 0 { len = 3 }
    if b3 != 0 { len = 4 }
    if b4 != 0 { len = 5 }
    if b5 != 0 { len = 6 }
    // Special: space (32) followed by zero is valid length=1
    if b0 == 32 && b1 == 0 { len = 1 }

    volatile_write_u8(e, len)
    volatile_write_u8(e + 1, b0)
    if len > 1 { volatile_write_u8(e + 2, b1) }
    if len > 2 { volatile_write_u8(e + 3, b2) }
    if len > 3 { volatile_write_u8(e + 4, b3) }
    if len > 4 { volatile_write_u8(e + 5, b4) }
    if len > 5 { volatile_write_u8(e + 6, b5) }
    // Zero rest
    let mut j: i64 = 1 + len
    while j < TOK_ENTRY_SIZE { volatile_write_u8(e + j, 0); j = j + 1 }
}

// ═══════════════════════════════════════════════════════════════
// Shell Commands
// ═══════════════════════════════════════════════════════════════

// tokenize <text> — encode text to token IDs
@kernel fn cmd_tokenize() {
    let len = cmdbuf_len()
    // "tokenize " = 9 chars
    if len <= 9 {
        cprintln("Usage: tokenize <text>", YELLOW_ON_BLACK)
        return
    }

    let text_addr: i64 = 0x6F800 + 9  // text starts after "tokenize "
    let text_len = len - 9

    // Use scratch for output token IDs (max 512 tokens)
    let out_addr = TOK_SCRATCH
    let max_tokens: i64 = 512
    let actual_len = if text_len > max_tokens { max_tokens } else { text_len }

    let n_tokens = tok_encode(text_addr, actual_len, out_addr)

    // Print input text
    cprint("Text: \"", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < actual_len {
        console_putchar(volatile_read_u8(text_addr + i), CYAN_ON_BLACK)
        i = i + 1
    }
    cprintln("\"", WHITE_ON_BLACK)

    // Print token count
    cprint("Tokens: ", WHITE_ON_BLACK)
    cprint_decimal(n_tokens, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // Print token IDs
    cprint("IDs: [", WHITE_ON_BLACK)
    i = 0
    while i < n_tokens {
        if i > 0 { cprint(", ", WHITE_ON_BLACK) }
        let tid = volatile_read_u64(out_addr + i * 8)
        cprint_decimal(tid, GREEN_ON_BLACK)
        i = i + 1
    }
    cprintln("]", WHITE_ON_BLACK)

    // Print decoded (verify roundtrip)
    cprint("Decode: \"", WHITE_ON_BLACK)
    i = 0
    while i < n_tokens {
        let tid = volatile_read_u64(out_addr + i * 8)
        // Decode into scratch after the token IDs
        let dec_buf = TOK_SCRATCH + max_tokens * 8
        let dec_len = tok_decode(tid, dec_buf)
        let mut j: i64 = 0
        while j < dec_len {
            let ch = volatile_read_u8(dec_buf + j)
            if ch >= 32 && ch < 127 {
                console_putchar(ch, CYAN_ON_BLACK)
            } else {
                // Non-printable: show as dot
                console_putchar(46, YELLOW_ON_BLACK)
            }
            j = j + 1
        }
        i = i + 1
    }
    cprintln("\"", WHITE_ON_BLACK)
}

// tok-info — show tokenizer status
@kernel fn cmd_tok_info() {
    cprintln("Tokenizer:", YELLOW_ON_BLACK)

    let mode = volatile_read_u64(TOK_META + TOK_M_MODE)
    cprint("  Mode:     ", WHITE_ON_BLACK)
    if mode == 0 {
        // "byte" = b(98)y(121)t(116)e(101)
        console_putchar(98, CYAN_ON_BLACK)
        console_putchar(121, CYAN_ON_BLACK)
        console_putchar(116, CYAN_ON_BLACK)
        console_putchar(101, CYAN_ON_BLACK)
    } else {
        // "BPE" = B(66)P(80)E(69)
        console_putchar(66, CYAN_ON_BLACK)
        console_putchar(80, CYAN_ON_BLACK)
        console_putchar(69, CYAN_ON_BLACK)
    }
    console_putchar(10, WHITE_ON_BLACK)

    cprint("  Vocab:    ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(TOK_META + TOK_M_VOCAB), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    cprint("  Max len:  ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(TOK_META + TOK_M_MAX_LEN), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    let encoded = volatile_read_u64(TOK_META + TOK_M_ENCODED)
    cprint("  Encoded:  ", WHITE_ON_BLACK)
    cprint_decimal(encoded, CYAN_ON_BLACK)
    cprintln(" tokens", WHITE_ON_BLACK)

    let decoded = volatile_read_u64(TOK_META + TOK_M_DECODED)
    cprint("  Decoded:  ", WHITE_ON_BLACK)
    cprint_decimal(decoded, CYAN_ON_BLACK)
    cprintln(" tokens", WHITE_ON_BLACK)

    if mode == 1 {
        let table_addr = volatile_read_u64(TOK_META + TOK_M_TABLE_ADDR)
        let n_frames = volatile_read_u64(TOK_META + TOK_M_TABLE_FRAMES)
        cprint("  Table at: 0x", WHITE_ON_BLACK)
        cprint_hex(table_addr, 8, CYAN_ON_BLACK)
        cprint(" (", WHITE_ON_BLACK)
        cprint_decimal(n_frames * 4, CYAN_ON_BLACK)
        cprintln(" KB)", WHITE_ON_BLACK)
    }
}

// tok-load <file.fjt> — load BPE token table
// tok-load test — generate and load test token table
@kernel fn cmd_tok_load() {
    let len = cmdbuf_len()
    // "tok-load " = 9 chars
    if len <= 9 {
        cprintln("Usage: tok-load <file.fjt>", YELLOW_ON_BLACK)
        cprintln("       tok-load test", YELLOW_ON_BLACK)
        return
    }

    // Check for "tok-load test"
    // "tok-load test" = 13 chars, 't'=116 at pos 9
    if len == 13 && volatile_read_u8(0x6F809) == 116 && volatile_read_u8(0x6F80A) == 101 && volatile_read_u8(0x6F80B) == 115 && volatile_read_u8(0x6F80C) == 116 {
        cprintln("Creating test token table...", CYAN_ON_BLACK)
        tok_create_test()
        cprintln("[OK] test.fjt created in RamFS", GREEN_ON_BLACK)

        // Load it
        let idx = ramfs_find("test.fjt")
        if idx < 0 {
            cprintln("[ERR] test.fjt not found", RED_ON_BLACK)
            return
        }
        let entry_addr = ramfs_entry_addr(idx)
        let data_ptr = volatile_read(entry_addr + 40)
        let file_size = volatile_read(entry_addr + 32)

        // Parse header
        let magic = mdl_read_u32(data_ptr)
        if magic != FJT_MAGIC {
            cprintln("[ERR] bad magic", RED_ON_BLACK)
            return
        }
        let vocab_size = mdl_read_u32(data_ptr + 8)
        let max_token_len = mdl_read_u32(data_ptr + 12)

        // Allocate + copy
        let table_bytes = vocab_size * TOK_ENTRY_SIZE
        let n_frames = (table_bytes + 4095) / 4096
        let table_addr = frame_alloc_contiguous(n_frames)
        if table_addr == -1 {
            cprintln("[ERR] OOM", RED_ON_BLACK)
            return
        }
        mdl_memcpy(table_addr, data_ptr + FJT_HEADER_SIZE, table_bytes)
        tok_build_fbi(table_addr, vocab_size)

        volatile_write_u64(TOK_META + TOK_M_MODE, 1)
        volatile_write_u64(TOK_META + TOK_M_VOCAB, vocab_size)
        volatile_write_u64(TOK_META + TOK_M_TABLE_ADDR, table_addr)
        volatile_write_u64(TOK_META + TOK_M_TABLE_FRAMES, n_frames)
        volatile_write_u64(TOK_META + TOK_M_MAX_LEN, max_token_len)

        cprint("[OK] Loaded ", GREEN_ON_BLACK)
        cprint_decimal(vocab_size, CYAN_ON_BLACK)
        cprintln(" tokens (BPE mode)", GREEN_ON_BLACK)
        return
    }

    // Load from RamFS
    let rc = tok_load_fjt(9)
    if rc == 0 {
        let vs = volatile_read_u64(TOK_META + TOK_M_VOCAB)
        cprint("[OK] Loaded ", GREEN_ON_BLACK)
        cprint_decimal(vs, CYAN_ON_BLACK)
        cprintln(" tokens (BPE mode)", GREEN_ON_BLACK)
    } else {
        cprint("[ERR] Load failed: E", RED_ON_BLACK)
        cprint_decimal(0 - rc, RED_ON_BLACK)
        console_putchar(10, RED_ON_BLACK)
    }
}

// tok-reset — switch back to byte-level mode
@kernel fn cmd_tok_reset() {
    // Free allocated frames if any
    let table_addr = volatile_read_u64(TOK_META + TOK_M_TABLE_ADDR)
    let n_frames = volatile_read_u64(TOK_META + TOK_M_TABLE_FRAMES)
    if table_addr > 0 && n_frames > 0 {
        let mut i: i64 = 0
        while i < n_frames {
            frame_free(table_addr + i * 4096)
            i = i + 1
        }
    }
    tok_init()
    cprintln("[OK] Tokenizer reset to byte-level", GREEN_ON_BLACK)
}
