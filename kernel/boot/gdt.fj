// FajarOS Nova — Global Descriptor Table (GDT)
// x86_64 long mode segmentation
//
// GDT Layout:
//   [0] 0x00: Null descriptor (required)
//   [1] 0x08: Kernel Code (CS, DPL=0, L=1 long mode, Execute/Read)
//   [2] 0x10: Kernel Data (SS, DPL=0, Read/Write)
//   [3] 0x18: User Code (CS, DPL=3, L=1 long mode, Execute/Read)
//   [4] 0x20: User Data (SS, DPL=3, Read/Write)
//   [5] 0x28: TSS descriptor (16 bytes — spans entries 5 and 6)

// Segment selectors
const KERNEL_CS: i64 = 0x08
const KERNEL_SS: i64 = 0x10
const USER_CS: i64 = 0x1B    // 0x18 | RPL=3
const USER_SS: i64 = 0x23    // 0x20 | RPL=3
const TSS_SEL: i64 = 0x28

// Initialize GDT with kernel + user segments and TSS
@kernel
fn gdt_init() {
