    // Kernel Code (0x08):
    //   Base=0, Limit=0, Access=0x9A (Present, DPL=0, Code, Execute/Read)
    //   Flags=0xA (L=1 long mode, G=0)
    //
    // Kernel Data (0x10):
    //   Base=0, Limit=0, Access=0x92 (Present, DPL=0, Data, Read/Write)
    //   Flags=0x0
    //
    // User Code (0x18):
    //   Base=0, Limit=0, Access=0xFA (Present, DPL=3, Code, Execute/Read)
    //   Flags=0xA (L=1 long mode)
    //
    // User Data (0x20):
    //   Base=0, Limit=0, Access=0xF2 (Present, DPL=3, Data, Read/Write)
    //   Flags=0x0

