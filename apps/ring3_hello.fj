// FajarOS Ring 3 Test — minimal user-mode program
// Compile: fj build --target x86_64-user apps/ring3_hello.fj -o build/ring3_hello.elf

fn main() {
    println("Hello from Ring 3!")
    let pid = getpid()
    println(pid)
    println("Exiting cleanly...")
    // Exit: call exit(0) which the compiler runtime provides
    exit(0)
}
