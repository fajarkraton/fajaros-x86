#!/usr/bin/env bash
# fajaros-x86 pre-commit hook — V26 Phase B2.5 + V28.5 + V29.P1
#
# Rejects commits that:
#   1. Break `make build-llvm` (kernel must always compile; since V29.P1
#      this also catches silent-build-failure — fj exits 0 without
#      producing an ELF — via the Makefile's test -f $(KERNEL_LLVM) gate)
#   2. Add new @unsafe annotations without a `// SAFETY:` comment
#   3. Add new TODO comments without a severity tag (P0/P1/P2/P3)
#   4. Introduce memory-map region overlaps (V28.5 prevention layer)
#   5. Remove the Makefile silent-build-failure gate itself (V29.P1
#      meta-check — prevents the prevention layer from being
#      accidentally deleted)
#
# Bypass with --no-verify if absolutely necessary (discouraged — leaves
# the kernel in an unverified state). Per CLAUDE.md §6 + V26 §B2.5.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ─────────────────────────────────────────────────────────────────
# Detect what kinds of files are staged
# ─────────────────────────────────────────────────────────────────
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACMR || true)
STAGED_FJ=$(echo "$STAGED_ALL" | grep -E '\.fj$' || true)
STAGED_BUILD=$(echo "$STAGED_ALL" | grep -E '\.(fj|S|ld)$|^Makefile$' || true)

# ─────────────────────────────────────────────────────────────────
# Check 1: make build-llvm (skip if nothing build-affecting is staged)
# ─────────────────────────────────────────────────────────────────
if [ -n "$STAGED_BUILD" ]; then
    printf '[1/5] make build-llvm ... '
    if ! make build-llvm > /tmp/fajaros_precommit_build.log 2>&1; then
        echo "❌"
        echo ""
        echo "make build-llvm failed. Last 25 lines:"
        echo "─────────────────────────────────────────────────────────"
        tail -25 /tmp/fajaros_precommit_build.log
        echo "─────────────────────────────────────────────────────────"
        echo "Full log: /tmp/fajaros_precommit_build.log"
        exit 1
    fi
    echo "✅"
else
    echo "[1/5] make build-llvm ... SKIPPED (no .fj/Makefile/.S/.ld changes)"
fi

# ─────────────────────────────────────────────────────────────────
# Check 2: @unsafe annotations require // SAFETY: comment
# Looks at ADDED lines only (not the whole file), so existing
# violations don't block unrelated commits.
# ─────────────────────────────────────────────────────────────────
if [ -n "$STAGED_FJ" ]; then
    printf '[2/5] @unsafe needs // SAFETY: ...'
    UNSAFE_VIOLATIONS=0
    UNSAFE_REPORT=""
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        [ -f "$f" ] || continue
        # Get unified diff with 2 lines of context so we can see preceding comments
        DIFF=$(git diff --cached -U2 -- "$f" 2>/dev/null || true)
        # Walk added lines (lines starting with + but not +++ headers)
        # For each added @unsafe line, check that the preceding 3 lines
        # (in the same diff hunk) contain // SAFETY:
        ADDED_LINENOS=$(echo "$DIFF" | grep -nE '^\+[^+]' | grep -E '@unsafe' | cut -d: -f1 || true)
        for ln in $ADDED_LINENOS; do
            # Look at lines (ln-3) to (ln-1) in the diff for SAFETY comment
            START=$((ln - 3))
            [ $START -lt 1 ] && START=1
            CONTEXT=$(echo "$DIFF" | sed -n "${START},${ln}p")
            if ! echo "$CONTEXT" | grep -qE '//\s*SAFETY:'; then
                UNSAFE_VIOLATIONS=$((UNSAFE_VIOLATIONS + 1))
                BAD_LINE=$(echo "$DIFF" | sed -n "${ln}p")
                UNSAFE_REPORT="$UNSAFE_REPORT  $f: $BAD_LINE
"
            fi
        done
    done <<< "$STAGED_FJ"
    if [ "$UNSAFE_VIOLATIONS" -gt 0 ]; then
        echo "❌"
        echo ""
        echo "$UNSAFE_VIOLATIONS new @unsafe annotation(s) without preceding // SAFETY: comment:"
        printf '%s' "$UNSAFE_REPORT"
        echo ""
        echo "Add a '// SAFETY: <reason>' comment within 3 lines above each @unsafe."
        echo "See CLAUDE.md §6 for the safety convention."
        exit 1
    fi
    echo "✅"
else
    echo "[2/5] @unsafe SAFETY ... SKIPPED (no .fj changes)"
fi

# ─────────────────────────────────────────────────────────────────
# Check 3: New TODOs require P0/P1/P2/P3 severity tag
# Same approach: only flag ADDED TODO lines, not pre-existing ones.
# ─────────────────────────────────────────────────────────────────
if [ -n "$STAGED_FJ" ]; then
    printf '[3/5] TODOs need P0/P1/P2/P3 severity ... '
    TODO_VIOLATIONS=0
    TODO_REPORT=""
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        [ -f "$f" ] || continue
        # Get added lines (no context needed — severity must be on same line as TODO)
        ADDED=$(git diff --cached -U0 -- "$f" 2>/dev/null | grep -E '^\+[^+]' || true)
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            if echo "$line" | grep -qE '\bTODO\b'; then
                if ! echo "$line" | grep -qE 'P[0-3]\b'; then
                    TODO_VIOLATIONS=$((TODO_VIOLATIONS + 1))
                    TODO_REPORT="$TODO_REPORT  $f: ${line#+}
"
                fi
            fi
        done <<< "$ADDED"
    done <<< "$STAGED_FJ"
    if [ "$TODO_VIOLATIONS" -gt 0 ]; then
        echo "❌"
        echo ""
        echo "$TODO_VIOLATIONS new TODO(s) without severity tag (P0/P1/P2/P3):"
        printf '%s' "$TODO_REPORT"
        echo ""
        echo "Add a severity tag inline, e.g.:"
        echo "  // TODO P0: critical bug, blocks production"
        echo "  // TODO P1: leak / correctness issue, fix this sprint"
        echo "  // TODO P2: hardening / nice-to-have"
        echo "  // TODO P3: cosmetic / refactor"
        exit 1
    fi
    echo "✅"
else
    echo "[3/5] TODO severity ... SKIPPED (no .fj changes)"
fi

# ─────────────────────────────────────────────────────────────────
# Check 4: Memory map collision detector (V28.5)
# Only runs if kernel memory-layout files are staged.
# ─────────────────────────────────────────────────────────────────
STAGED_MEM=$(echo "$STAGED_ALL" | grep -E 'model_loader\.fj|transformer\.fj|kmatrix\.fj' || true)
if [ -n "$STAGED_MEM" ]; then
    printf '[4/5] memory map collisions ... '
    if python3 scripts/check_memory_map.py > /tmp/fajaros_memmap.log 2>&1; then
        echo "✅"
    else
        echo "❌"
        echo ""
        echo "Memory map overlap detected!"
        cat /tmp/fajaros_memmap.log
        echo ""
        echo "Fix the address constants in the flagged files, then re-commit."
        exit 1
    fi
else
    echo "[4/5] memory map collisions ... SKIPPED (no layout files changed)"
fi

# ─────────────────────────────────────────────────────────────────
# Check 5: Makefile silent-build-failure gate must remain in place
# (V29.P1 meta-check — prevents removal of the prevention layer itself)
# Only runs if the Makefile is staged; otherwise the existing gate is
# safe and the check is unnecessary.
# ─────────────────────────────────────────────────────────────────
STAGED_MAKEFILE=$(echo "$STAGED_ALL" | grep -E '^Makefile$' || true)
if [ -n "$STAGED_MAKEFILE" ]; then
    printf '[5/5] Makefile ELF-gate intact ... '
    # The gate is: `test -f $(KERNEL_LLVM)` immediately after the
    # `fj build ... -o $(KERNEL_LLVM)` command in the build-llvm
    # target. Removing this re-enables the silent-build-failure bug
    # class that V29.P1 was created to close.
    if grep -qE 'test -f \$\(KERNEL_LLVM\)' Makefile; then
        echo "✅"
    else
        echo "❌"
        echo ""
        echo "Makefile is missing the V29.P1 silent-build-failure gate."
        echo ""
        echo "The 'build-llvm' target must contain a 'test -f \$(KERNEL_LLVM)'"
        echo "guard after 'fj build' to catch cases where fj exits 0 without"
        echo "emitting the output ELF. Removing this gate reopens the bug"
        echo "class documented in fajar-lang/docs/V29_P1_COMPILER_ENHANCEMENT_PLAN.md"
        echo ""
        echo "Restore the guard or explain in the commit message why it's"
        echo "being removed. Use --no-verify to force (strongly discouraged)."
        exit 1
    fi
else
    echo "[5/5] Makefile ELF-gate ... SKIPPED (Makefile not staged)"
fi

echo ""
echo "✅ fajaros-x86 pre-commit OK (build, @unsafe SAFETY, TODO severity, memory map, ELF gate)"
