// Punctuation and common symbols
@kernel fn font_gen_punctuation(s: i64) {
    // ! (33)
    font_set_glyph_row(33, s, 2, 0x18); font_set_glyph_row(33, s, 3, 0x18)
    font_set_glyph_row(33, s, 4, 0x18); font_set_glyph_row(33, s, 5, 0x18)
    font_set_glyph_row(33, s, 6, 0x18); font_set_glyph_row(33, s, 8, 0x18)
    // . (46)
    font_set_glyph_row(46, s, 8, 0x18)
    // , (44)
    font_set_glyph_row(44, s, 8, 0x18); font_set_glyph_row(44, s, 9, 0x30)
    // : (58)
    font_set_glyph_row(58, s, 4, 0x18); font_set_glyph_row(58, s, 8, 0x18)
    // ; (59)
    font_set_glyph_row(59, s, 4, 0x18); font_set_glyph_row(59, s, 8, 0x18)
    font_set_glyph_row(59, s, 9, 0x30)
    // - (45)
    font_set_glyph_row(45, s, 5, 0x7E)
    // = (61)
    font_set_glyph_row(61, s, 4, 0x7E); font_set_glyph_row(61, s, 6, 0x7E)
    // + (43)
    font_set_glyph_row(43, s, 4, 0x18); font_set_glyph_row(43, s, 5, 0x7E)
    font_set_glyph_row(43, s, 6, 0x18)
    // * (42)
    font_set_glyph_row(42, s, 3, 0x66); font_set_glyph_row(42, s, 4, 0x3C)
    font_set_glyph_row(42, s, 5, 0xFF); font_set_glyph_row(42, s, 6, 0x3C)
    font_set_glyph_row(42, s, 7, 0x66)
    // / (47)
    font_set_glyph_row(47, s, 2, 0x06); font_set_glyph_row(47, s, 3, 0x0C)
    font_set_glyph_row(47, s, 4, 0x18); font_set_glyph_row(47, s, 5, 0x30)
    font_set_glyph_row(47, s, 6, 0x60); font_set_glyph_row(47, s, 7, 0x40)
    // ( (40) and ) (41)
    font_set_glyph_row(40, s, 2, 0x0C); font_set_glyph_row(40, s, 3, 0x18)
    font_set_glyph_row(40, s, 4, 0x30); font_set_glyph_row(40, s, 5, 0x30)
    font_set_glyph_row(40, s, 6, 0x30); font_set_glyph_row(40, s, 7, 0x18)
    font_set_glyph_row(40, s, 8, 0x0C)
    font_set_glyph_row(41, s, 2, 0x30); font_set_glyph_row(41, s, 3, 0x18)
    font_set_glyph_row(41, s, 4, 0x0C); font_set_glyph_row(41, s, 5, 0x0C)
    font_set_glyph_row(41, s, 6, 0x0C); font_set_glyph_row(41, s, 7, 0x18)
    font_set_glyph_row(41, s, 8, 0x30)
    // [ (91) and ] (93)
    font_set_glyph_row(91, s, 2, 0x3C); font_set_glyph_row(91, s, 3, 0x30)
    font_set_glyph_row(91, s, 4, 0x30); font_set_glyph_row(91, s, 5, 0x30)
    font_set_glyph_row(91, s, 6, 0x30); font_set_glyph_row(91, s, 7, 0x30)
    font_set_glyph_row(91, s, 8, 0x3C)
    font_set_glyph_row(93, s, 2, 0x3C); font_set_glyph_row(93, s, 3, 0x0C)
    font_set_glyph_row(93, s, 4, 0x0C); font_set_glyph_row(93, s, 5, 0x0C)
    font_set_glyph_row(93, s, 6, 0x0C); font_set_glyph_row(93, s, 7, 0x0C)
    font_set_glyph_row(93, s, 8, 0x3C)
    // _ (95)
    font_set_glyph_row(95, s, 9, 0xFF)
    // " (34)
    font_set_glyph_row(34, s, 2, 0x66); font_set_glyph_row(34, s, 3, 0x66)
    // ' (39)
    font_set_glyph_row(39, s, 2, 0x18); font_set_glyph_row(39, s, 3, 0x18)
    // # (35)
    font_set_glyph_row(35, s, 3, 0x6C); font_set_glyph_row(35, s, 4, 0xFE)
    font_set_glyph_row(35, s, 5, 0x6C); font_set_glyph_row(35, s, 6, 0xFE)
    font_set_glyph_row(35, s, 7, 0x6C)
    // @ (64)
    font_set_glyph_row(64, s, 2, 0x3C); font_set_glyph_row(64, s, 3, 0x42)
    font_set_glyph_row(64, s, 4, 0x5A); font_set_glyph_row(64, s, 5, 0x5A)
    font_set_glyph_row(64, s, 6, 0x5E); font_set_glyph_row(64, s, 7, 0x40)
    font_set_glyph_row(64, s, 8, 0x3C)
    // < (60) and > (62)
    font_set_glyph_row(60, s, 3, 0x0C); font_set_glyph_row(60, s, 4, 0x18)
    font_set_glyph_row(60, s, 5, 0x30); font_set_glyph_row(60, s, 6, 0x18)
    font_set_glyph_row(60, s, 7, 0x0C)
    font_set_glyph_row(62, s, 3, 0x30); font_set_glyph_row(62, s, 4, 0x18)
    font_set_glyph_row(62, s, 5, 0x0C); font_set_glyph_row(62, s, 6, 0x18)
    font_set_glyph_row(62, s, 7, 0x30)
    // | (124)
    font_set_glyph_row(124, s, 2, 0x18); font_set_glyph_row(124, s, 3, 0x18)
    font_set_glyph_row(124, s, 4, 0x18); font_set_glyph_row(124, s, 5, 0x18)
    font_set_glyph_row(124, s, 6, 0x18); font_set_glyph_row(124, s, 7, 0x18)
    font_set_glyph_row(124, s, 8, 0x18)
    // ~ (126)
    font_set_glyph_row(126, s, 4, 0x76); font_set_glyph_row(126, s, 5, 0xDC)
    // ^ (94)
    font_set_glyph_row(94, s, 2, 0x18); font_set_glyph_row(94, s, 3, 0x3C)
    font_set_glyph_row(94, s, 4, 0x66)
    // & (38)
    font_set_glyph_row(38, s, 2, 0x38); font_set_glyph_row(38, s, 3, 0x6C)
    font_set_glyph_row(38, s, 4, 0x38); font_set_glyph_row(38, s, 5, 0x76)
    font_set_glyph_row(38, s, 6, 0xDC); font_set_glyph_row(38, s, 7, 0xCC)
    font_set_glyph_row(38, s, 8, 0x76)
    // % (37)
    font_set_glyph_row(37, s, 2, 0x62); font_set_glyph_row(37, s, 3, 0x66)
    font_set_glyph_row(37, s, 4, 0x0C); font_set_glyph_row(37, s, 5, 0x18)
    font_set_glyph_row(37, s, 6, 0x30); font_set_glyph_row(37, s, 7, 0x66)
    font_set_glyph_row(37, s, 8, 0x46)
    // $ (36)
    font_set_glyph_row(36, s, 2, 0x18); font_set_glyph_row(36, s, 3, 0x3E)
    font_set_glyph_row(36, s, 4, 0x60); font_set_glyph_row(36, s, 5, 0x3C)
    font_set_glyph_row(36, s, 6, 0x06); font_set_glyph_row(36, s, 7, 0x7C)
    font_set_glyph_row(36, s, 8, 0x18)
    // ? (63)
    font_set_glyph_row(63, s, 2, 0x3C); font_set_glyph_row(63, s, 3, 0x66)
    font_set_glyph_row(63, s, 4, 0x06); font_set_glyph_row(63, s, 5, 0x0C)
    font_set_glyph_row(63, s, 6, 0x18); font_set_glyph_row(63, s, 8, 0x18)
    // { (123) and } (125)
    font_set_glyph_row(123, s, 2, 0x0E); font_set_glyph_row(123, s, 3, 0x18)
    font_set_glyph_row(123, s, 4, 0x18); font_set_glyph_row(123, s, 5, 0x70)
    font_set_glyph_row(123, s, 6, 0x18); font_set_glyph_row(123, s, 7, 0x18)
    font_set_glyph_row(123, s, 8, 0x0E)
    font_set_glyph_row(125, s, 2, 0x70); font_set_glyph_row(125, s, 3, 0x18)
    font_set_glyph_row(125, s, 4, 0x18); font_set_glyph_row(125, s, 5, 0x0E)
    font_set_glyph_row(125, s, 6, 0x18); font_set_glyph_row(125, s, 7, 0x18)
    font_set_glyph_row(125, s, 8, 0x70)
    // \\ (92)
    font_set_glyph_row(92, s, 2, 0x60); font_set_glyph_row(92, s, 3, 0x30)
    font_set_glyph_row(92, s, 4, 0x18); font_set_glyph_row(92, s, 5, 0x0C)
    font_set_glyph_row(92, s, 6, 0x06)
    // ` (96)
    font_set_glyph_row(96, s, 2, 0x30); font_set_glyph_row(96, s, 3, 0x18)
}

// ═══════════════════════════════════════════════════════════════
// Box Drawing Characters (for TUI/terminal borders)
// ═══════════════════════════════════════════════════════════════

@kernel fn font_generate_box_drawing(s: i64) {
    // ─ horizontal (196)
    font_set_glyph_row(196, s, 5, 0xFF)
    // │ vertical (179)
    font_set_glyph_row(179, s, 0, 0x18); font_set_glyph_row(179, s, 1, 0x18)
    font_set_glyph_row(179, s, 2, 0x18); font_set_glyph_row(179, s, 3, 0x18)
    font_set_glyph_row(179, s, 4, 0x18); font_set_glyph_row(179, s, 5, 0x18)
    font_set_glyph_row(179, s, 6, 0x18); font_set_glyph_row(179, s, 7, 0x18)
    font_set_glyph_row(179, s, 8, 0x18); font_set_glyph_row(179, s, 9, 0x18)
    // ┌ top-left (218)
    font_set_glyph_row(218, s, 5, 0x1F); font_set_glyph_row(218, s, 6, 0x18)
    font_set_glyph_row(218, s, 7, 0x18); font_set_glyph_row(218, s, 8, 0x18)
    // ┐ top-right (191)
    font_set_glyph_row(191, s, 5, 0xF8); font_set_glyph_row(191, s, 6, 0x18)
    font_set_glyph_row(191, s, 7, 0x18); font_set_glyph_row(191, s, 8, 0x18)
    // └ bottom-left (192)
    font_set_glyph_row(192, s, 2, 0x18); font_set_glyph_row(192, s, 3, 0x18)
    font_set_glyph_row(192, s, 4, 0x18); font_set_glyph_row(192, s, 5, 0x1F)
    // ┘ bottom-right (217)
    font_set_glyph_row(217, s, 2, 0x18); font_set_glyph_row(217, s, 3, 0x18)
    font_set_glyph_row(217, s, 4, 0x18); font_set_glyph_row(217, s, 5, 0xF8)
    // ├ left-T (195)
    font_set_glyph_row(195, s, 2, 0x18); font_set_glyph_row(195, s, 3, 0x18)
    font_set_glyph_row(195, s, 4, 0x18); font_set_glyph_row(195, s, 5, 0x1F)
    font_set_glyph_row(195, s, 6, 0x18); font_set_glyph_row(195, s, 7, 0x18)
    // ┤ right-T (180)
    font_set_glyph_row(180, s, 2, 0x18); font_set_glyph_row(180, s, 3, 0x18)
    font_set_glyph_row(180, s, 4, 0x18); font_set_glyph_row(180, s, 5, 0xF8)
    font_set_glyph_row(180, s, 6, 0x18); font_set_glyph_row(180, s, 7, 0x18)
    // ┬ top-T (194)
    font_set_glyph_row(194, s, 5, 0xFF); font_set_glyph_row(194, s, 6, 0x18)
    font_set_glyph_row(194, s, 7, 0x18)
    // ┴ bottom-T (193)
    font_set_glyph_row(193, s, 3, 0x18); font_set_glyph_row(193, s, 4, 0x18)
    font_set_glyph_row(193, s, 5, 0xFF)
    // ┼ cross (197)
    font_set_glyph_row(197, s, 2, 0x18); font_set_glyph_row(197, s, 3, 0x18)
    font_set_glyph_row(197, s, 4, 0x18); font_set_glyph_row(197, s, 5, 0xFF)
    font_set_glyph_row(197, s, 6, 0x18); font_set_glyph_row(197, s, 7, 0x18)
    // █ full block (219)
    font_set_glyph_row(219, s, 0, 0xFF); font_set_glyph_row(219, s, 1, 0xFF)
    font_set_glyph_row(219, s, 2, 0xFF); font_set_glyph_row(219, s, 3, 0xFF)
    font_set_glyph_row(219, s, 4, 0xFF); font_set_glyph_row(219, s, 5, 0xFF)
    font_set_glyph_row(219, s, 6, 0xFF); font_set_glyph_row(219, s, 7, 0xFF)
    font_set_glyph_row(219, s, 8, 0xFF); font_set_glyph_row(219, s, 9, 0xFF)
    // ▓ dense shade (178)
    font_set_glyph_row(178, s, 0, 0xDB); font_set_glyph_row(178, s, 1, 0x6D)
    font_set_glyph_row(178, s, 2, 0xDB); font_set_glyph_row(178, s, 3, 0x6D)
    font_set_glyph_row(178, s, 4, 0xDB); font_set_glyph_row(178, s, 5, 0x6D)
    font_set_glyph_row(178, s, 6, 0xDB); font_set_glyph_row(178, s, 7, 0x6D)
    // ▒ medium shade (177)
    font_set_glyph_row(177, s, 0, 0xAA); font_set_glyph_row(177, s, 1, 0x55)
    font_set_glyph_row(177, s, 2, 0xAA); font_set_glyph_row(177, s, 3, 0x55)
    font_set_glyph_row(177, s, 4, 0xAA); font_set_glyph_row(177, s, 5, 0x55)
    font_set_glyph_row(177, s, 6, 0xAA); font_set_glyph_row(177, s, 7, 0x55)
    // ░ light shade (176)
    font_set_glyph_row(176, s, 0, 0x22); font_set_glyph_row(176, s, 1, 0x88)
    font_set_glyph_row(176, s, 2, 0x22); font_set_glyph_row(176, s, 3, 0x88)
    font_set_glyph_row(176, s, 4, 0x22); font_set_glyph_row(176, s, 5, 0x88)
    font_set_glyph_row(176, s, 6, 0x22); font_set_glyph_row(176, s, 7, 0x88)
    // ▄ lower half (220)
    font_set_glyph_row(220, s, 5, 0xFF); font_set_glyph_row(220, s, 6, 0xFF)
    font_set_glyph_row(220, s, 7, 0xFF); font_set_glyph_row(220, s, 8, 0xFF)
    font_set_glyph_row(220, s, 9, 0xFF)
    // ▀ upper half (223)
    font_set_glyph_row(223, s, 0, 0xFF); font_set_glyph_row(223, s, 1, 0xFF)
    font_set_glyph_row(223, s, 2, 0xFF); font_set_glyph_row(223, s, 3, 0xFF)
    font_set_glyph_row(223, s, 4, 0xFF)
}

// ═══════════════════════════════════════════════════════════════
// Scaled Font Generation — Copy 8×16 to other sizes
// ═══════════════════════════════════════════════════════════════

// Generate smaller fonts by scaling down the 8×16 glyphs
@kernel fn font_generate_ascii_8() {
    // 8×8: take every other row from 8×16
    let mut ch: i64 = 32
    while ch < 127 {
        let src = font_glyph_addr_size(ch, 3)  // 8×16 source
        let dst = font_glyph_addr_size(ch, 0)  // 8×8 destination
        volatile_write_u8(dst, volatile_read_u8(src + 2))
        volatile_write_u8(dst + 1, volatile_read_u8(src + 3))
        volatile_write_u8(dst + 2, volatile_read_u8(src + 4))
        volatile_write_u8(dst + 3, volatile_read_u8(src + 5))
        volatile_write_u8(dst + 4, volatile_read_u8(src + 6))
        volatile_write_u8(dst + 5, volatile_read_u8(src + 7))
        volatile_write_u8(dst + 6, volatile_read_u8(src + 8))
        volatile_write_u8(dst + 7, volatile_read_u8(src + 9))
        ch = ch + 1
    }
}

@kernel fn font_generate_ascii_12() {
    // 8×12: copy rows 1-12 from 8×16 (skip top/bottom padding)
    let mut ch: i64 = 32
    while ch < 127 {
        let src = font_glyph_addr_size(ch, 3)
        let dst = font_glyph_addr_size(ch, 1)
        let mut r: i64 = 0
        while r < 12 { volatile_write_u8(dst + r, volatile_read_u8(src + r + 1)); r = r + 1 }
        ch = ch + 1
    }
}

@kernel fn font_generate_ascii_14() {
    // 8×14: copy rows 0-13 from 8×16
    let mut ch: i64 = 32
    while ch < 127 {
        let src = font_glyph_addr_size(ch, 3)
        let dst = font_glyph_addr_size(ch, 2)
        let mut r: i64 = 0
        while r < 14 { volatile_write_u8(dst + r, volatile_read_u8(src + r)); r = r + 1 }
        ch = ch + 1
    }
}

@kernel fn font_generate_ascii_20() {
    // 8×20: stretch 8×16 by duplicating every 4th row
    let mut ch: i64 = 32
    while ch < 127 {
        let src = font_glyph_addr_size(ch, 3)
        let dst = font_glyph_addr_size(ch, 4)
        let mut sr: i64 = 0
        let mut dr: i64 = 0
        while sr < 16 {
            volatile_write_u8(dst + dr, volatile_read_u8(src + sr))
            dr = dr + 1
            if sr % 4 == 0 {
                // Duplicate this row for stretch
                volatile_write_u8(dst + dr, volatile_read_u8(src + sr))
                dr = dr + 1
            }
            sr = sr + 1
        }
        ch = ch + 1
    }
}

// ═══════════════════════════════════════════════════════════════
// Shell Command — Font Demo
// ═══════════════════════════════════════════════════════════════

@kernel fn cmd_font() {
    cprintln("=== Font System ===", YELLOW_ON_BLACK)
    cprintln("Sizes: 8x8, 8x12, 8x14, 8x16, 8x20", WHITE_ON_BLACK)
    cprint("Active size: ", WHITE_ON_BLACK)
    let idx = font_get_size()
    cprint_decimal(font_get_width(), WHITE_ON_BLACK)
    cprint("x", WHITE_ON_BLACK)
    cprintln_decimal(font_get_height(), WHITE_ON_BLACK)
    cprint("Glyphs: 256 per size (ASCII + box drawing)", WHITE_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)
    cprint("Bold: ", WHITE_ON_BLACK)
    if volatile_read_u64(FONT_STORE + FONT_BOLD_FLAG) != 0 { cprintln("on", GREEN_ON_BLACK) }
    else { cprintln("off", WHITE_ON_BLACK) }
    cprint("Proportional: ", WHITE_ON_BLACK)
    if volatile_read_u64(FONT_STORE + FONT_PROPORTIONAL) != 0 { cprintln("on", GREEN_ON_BLACK) }
    else { cprintln("off (monospace)", WHITE_ON_BLACK) }
}
